                crossorigin="anonymous" />
        </noscript>


        <!-- Google Tag Manager -->
        <script is:inline>
            // @ts-nocheck
            (function (w, d, s, l, i) {
                // @ts-ignore
                w[l] = w[l] || [];
                // @ts-ignore
                w[l].push({
                    "gtm.start": new Date().getTime(),
                    event: "gtm.js",
                });
                var f = d.getElementsByTagName(s)[0],
                    j = d.createElement(s),
                    dl = l != "dataLayer" ? "&l=" + l : "";
                if (j instanceof HTMLScriptElement) {
                    j.async = true;
                    j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
                }
                if (f && f.parentNode) {
                    f.parentNode.insertBefore(j, f);
                }
            })(window, document, "script", "dataLayer", "GTM-P3G8VXDF");
        </script>

        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-E1FESF3403"></script>
        <script is:inline>
            // @ts-nocheck
            window.dataLayer = window.dataLayer || [];
            /** @type {any[]} */
            var dataLayer = window.dataLayer;
            function gtag() {
                dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", "G-E1FESF3403");
        </script>

        <!-- ✅ THEME VARIABLES INJECTION -->
        {
        theme && (
        <style is:global set:html={`
            :root {
                --c-primary: ${theme.primary} !important;
                --c-primary-gradient: ${theme.primaryGradient ?? theme.primary} !important;
                --c-primary-hover: ${theme.primaryHover} !important;
                --ranking-primary: ${theme.primary} !important;
                --ranking-primary-gradient: ${theme.primaryGradient ?? theme.primary} !important;
                --ranking-primary-alpha: ${theme.primary}33 !important;
            }

            /* Apply these when theme matches (e.g. forced or selected) */
            :root[data-theme="light"], :root:not([data-theme="dark"]) {
                ${!isForcedDarkMode ? `
                --c-bg: ${theme.bg} !important;
                --c-surface: ${theme.surface} !important;
                --c-surface-alt: ${theme.surfaceAlt} !important;
                --c-border: ${theme.border} !important;
                --c-content: ${theme.content} !important;
                --c-content-muted: ${theme.textMuted} !important;
                --c-content-secondary: ${theme.content} !important;
                ` : ''}
            }

            :root[data-theme="dark"] {
                ${isForcedDarkMode ? `
                --c-bg: ${theme.bg} !important;
                --c-surface: ${theme.surface} !important;
                --c-surface-alt: ${theme.surfaceAlt} !important;
                --c-border: ${theme.border} !important;
                --c-content: ${theme.content} !important;
                --c-content-muted: ${theme.textMuted} !important;
                --c-content-secondary: ${theme.content} !important;
                ` : ''}
            }
        `} />
        )
        }

        <slot name="head" />
    </head>

    <body>
