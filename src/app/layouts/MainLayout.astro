---
// MainLayout.astro

import type { ThemeConfig } from "@/types/event";

import "@/shared/styles/main.scss";
import IconSprite from "@/shared/components/IconSprite.astro";
import { Image } from "astro:assets";
import logoWhite from "@/shared/assets/logo/WHITE.png";
import logoBlack from "@/shared/assets/logo/BLACK.png";
import logoNavy from "@/shared/assets/logo/NAVY.png";

interface Props {
    title?: string;
    description?: string;
    theme?: ThemeConfig;
    forcedTheme?: "light" | "dark";
    socialImage?: string;
}


const {
    title = "Niya BNK48 - Fan Website",
    description = "ติดตามและเป็นกำลังใจให้กับ Niya BNK48 ผ่านเว็บไซต์แฟนคลับอย่างเป็นทางการนี้ ที่นี่คุณจะได้พบกับข่าวสารล่าสุด ตารางงาน กิจกรรม และคลังรูปภาพของ Niya BNK48 ที่ทำไว้เพื่อแฟนคลับทุกคน",
    theme,
    forcedTheme,
    socialImage,
} = Astro.props;

const defaultSocialImage =
    "https://little-nemo-of-niya.vercel.app/logo/apple-touch-icon.png";
const resolvedSocialImage = socialImage
    ? /^https?:\/\//i.test(socialImage)
        ? socialImage
        : new URL(socialImage, Astro.url).href
    : defaultSocialImage;


/** `/_vercel/speed-insights/script.js` exists only on the Vercel platform, not in `astro dev` / local preview. */
const enableVercelSpeedInsights =
    import.meta.env.PROD &&
    (process.env.VERCEL === "1" || import.meta.env.VERCEL === "1");

// ── Theme Logic ──────────────────────────────────────────────────────────────
const isForcedLightMode = forcedTheme === "light";
const isForcedDarkMode = forcedTheme === "dark";



// Schema Markup Data สำหรับ SEO
const schemaData = {
    personSchema: {
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": "https://little-nemo-of-niya.vercel.app/#person",
        name: "Niya",
        alternateName: ["นีญ่า", "Niya BNK48", "นีญ่า บีเอ็นเค48", "Suvibha Laithomya", "สุวิภาส์ ลายถมยา"],
        description: "สมาชิกของวง BNK48",
        memberOf: {
            "@type": "Organization",
            "@id": "https://little-nemo-of-niya.vercel.app/",
            name: "Niya BNK48 Fan Website",
            logo: "/logo/icon.png",
            url: "https://little-nemo-of-niya.vercel.app/",
        },
        url: "https://little-nemo-of-niya.vercel.app/",
        sameAs: [
            "https://www.instagram.com/niya.bnk48official/",
            "https://www.facebook.com/niya.bnk48official",
            "https://www.tiktok.com/@niya.bnk48.official",
            "https://www.youtube.com/@niya.bnk48official",
            "https://x.com/niya_bnk48",
            "https://www.facebook.com/niya.bnk48official",
        ],
    },

    websiteSchema: {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": "https://little-nemo-of-niya.vercel.app/#website",
        name: "Niya BNK48 - Fan Website",
        description: description,
        url: "https://little-nemo-of-niya.vercel.app/",
        potentialAction: {
