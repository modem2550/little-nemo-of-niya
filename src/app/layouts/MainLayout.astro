            name: "Niya BNK48 Fan Community",
        },
    },

    breadcrumbSchema: {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
            {
                "@type": "ListItem",
                position: 1,
                name: "home",
                item: "https://little-nemo-of-niya.vercel.app/",
            },
            {
                "@type": "ListItem",
                position: 2,
                name: "event",
                item: "https://little-nemo-of-niya.vercel.app/#event",
            },
            {
                "@type": "ListItem",
                position: 3,
