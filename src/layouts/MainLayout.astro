---
// MainLayout.astro

import type { ThemeConfig } from "@/types/event";

import "../styles/main.scss";
import "../styles/animations.scss";
import IconSprite from "../components/common/IconSprite.astro";

interface Props {
    title?: string;
    description?: string;
    theme?: ThemeConfig;
}

const {
    title = "Niya BNK48 - Fan Website",
    description = "ติดตามและเป็นกำลังใจให้กับ Niya BNK48 ผ่านเว็บไซต์แฟนคลับอย่างเป็นทางการนี้ ที่นี่คุณจะได้พบกับข่าวสารล่าสุด ตารางงาน กิจกรรม และคลังรูปภาพของ Niya BNK48 ที่ทำไว้เพื่อแฟนคลับทุกคน",
    theme,
} = Astro.props;

/** `/_vercel/speed-insights/script.js` exists only on the Vercel platform, not in `astro dev` / local preview. */
const enableVercelSpeedInsights =
    import.meta.env.PROD &&
    (process.env.VERCEL === "1" || import.meta.env.VERCEL === "1");

// Schema Markup Data สำหรับ SEO
const schemaData = {
    personSchema: {
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": "https://little-nemo-of-niya.vercel.app/#person",
        name: "Niya",
        alternateName: ["นีญ่า", "Niya BNK48", "นีญ่า บีเอ็นเค48", "Suvibha Laithomya", "สุวิภาส์ ลายถมยา"],
        description: "สมาชิกของวง BNK48",
        memberOf: {
            "@type": "Organization",
            "@id": "https://bnk48.com/",
            name: "BNK48",
            logo: "https://bnk48.com/logo.png",
            url: "https://bnk48.com/",
        },
        url: "https://little-nemo-of-niya.vercel.app/",
        sameAs: [
            "https://www.instagram.com/niya.bnk48official/",
            "https://www.facebook.com/niya.bnk48official",
            "https://www.tiktok.com/@niya.bnk48.official",
            "https://www.youtube.com/@niya.bnk48official",
            "https://x.com/niya_bnk48",
        ],
    },

    websiteSchema: {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": "https://little-nemo-of-niya.vercel.app/#website",
        name: "Niya BNK48 - Fan Website",
        description: description,
        url: "https://little-nemo-of-niya.vercel.app/",
        potentialAction: {
            "@type": "SearchAction",
            target: {
                "@type": "EntryPoint",
                urlTemplate:
                    "https://little-nemo-of-niya.vercel.app/?search={search_term_string}",
            },
            "query-input": "required name=search_term_string",
        },
        author: {
            "@type": "Person",
            name: "Niya BNK48 Fan Community",
        },
    },

    breadcrumbSchema: {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
            {
                "@type": "ListItem",
                position: 1,
                name: "Home",
                item: "https://little-nemo-of-niya.vercel.app/",
            },
            {
                "@type": "ListItem",
                position: 2,
                name: "About Niya",
                item: "https://little-nemo-of-niya.vercel.app/#info",
            },
            {
                "@type": "ListItem",
                position: 3,
                name: "Events",
                item: "https://little-nemo-of-niya.vercel.app/#event",
            },
            {
                "@type": "ListItem",
                position: 4,
                name: "Gallery",
                item: "https://little-nemo-of-niya.vercel.app/#library",
            },
        ],
    },

    organizationSchema: {
        "@context": "https://schema.org",
        "@type": "Organization",
        "@id": "https://little-nemo-of-niya.vercel.app/#organization",
        name: "Niya BNK48 Official Fan Site",
        url: "https://little-nemo-of-niya.vercel.app/",
        logo: "https://little-nemo-of-niya.vercel.app/logo/android-chrome-512x512.png",
        description: "Niya BNK48 แฟนคลับอย่างเป็นทางการ",
        sameAs: [
            "https://line.me/ti/g2/YYQYpuFlsvlTQz6KyvKM7m0zmLJ39JlzdphDqA",
            "https://www.instagram.com/niyabnk48_thfc/",
            "https://www.facebook.com/profile.php?id=61556940780361",
            "https://www.tiktok.com/@niya.bnk48.thfc",
            "https://x.com/niyabnk48_thfc",
            "https://www.youtube.com/@NiyaBNK48ThailandFanclub",
        ],
        founder: {
            "@type": "Person",
            name: "Niya (นีญ่า) BNK48",
        },
    },
};
---

<!doctype html>
<meta name="title" content={title} />
<meta name="description" content={description} />

<html lang="th">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <meta
            name="keywords"
            content="niya, niya bnk48, นีญ่า, นีญ่า bnk48, bnk48 niya, niya thai idol, บีเอ็นเค48"
        />
        <meta name="robots" content="index, follow" />

        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:type" content="website" />
        <meta
            property="og:image"
            content="https://little-nemo-of-niya.vercel.app/logo/apple-touch-icon.png"
        />
        <meta property="og:site_name" content="Niya BNK48 Fan Site" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta
            name="twitter:image"
            content="https://little-nemo-of-niya.vercel.app/logo/apple-touch-icon.png"
        />

        <meta name="theme-color" content="#ffffff" />
        <meta name="mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta
            name="apple-mobile-web-app-status-bar-style"
            content="black-translucent"
        />

        <link rel="canonical" href={Astro.url} />
        <link rel="alternate" hreflang="th" href={Astro.url} />

        <link rel="icon" href="/logo/logo 32x32.png" sizes="32x32" />
        <link rel="apple-touch-icon" href="/logo/apple-touch-icon.png" />
        <link rel="manifest" href="/site.webmanifest" />

        <title>{title}</title>

        <meta
            name="google-site-verification"
            content="LND_1q1wO4RiVRx123fm8FVWPBYCW2EWkpnWWH_hPjY"
        />

        <!-- Schema Markup for SEO -->
        <script
            type="application/ld+json"
            set:html={JSON.stringify(schemaData.personSchema)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(schemaData.websiteSchema)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(schemaData.breadcrumbSchema)}
        />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(schemaData.organizationSchema)}
        />

        <!-- Preload critical resources -->
        <link
            rel="preload"
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            as="style"
            crossorigin="anonymous"
        />

        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&family=Noto+Sans+Thai:wght@100..900&display=swap"
            rel="stylesheet"
            media="print"
            onload="this.setAttribute('media','all')"
            crossorigin="anonymous"
        />
        <noscript
            ><link
                href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&family=Noto+Sans+Thai:wght@100..900&display=swap"
                rel="stylesheet"
                crossorigin="anonymous"
            /></noscript
        >

        <!-- Bootstrap CSS -->
        <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
            rel="stylesheet"
            media="print"
            onload="this?.setAttribute('media','all')"
            crossorigin="anonymous"
        />
        <noscript
            ><link
                href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
                rel="stylesheet"
                crossorigin="anonymous"
            /></noscript
        >

        <link rel="preconnect" href="https://cdn.jsdelivr.net" />

        <!-- Font Awesome -->
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@7.1.0/css/all.min.css"
            integrity="sha256-4rTIfo5GQTi/7UJqoyUJQKzxW8VN/YBH31+Cy+vTZj4="
            crossorigin="anonymous"
            media="print"
            onload="this?.setAttribute('media','all')"
        />
        <noscript
            ><link
                rel="stylesheet"
                href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@7.1.0/css/all.min.css"
                crossorigin="anonymous"
            /></noscript
        >

        <script is:inline>
            // @ts-nocheck
            window.va =
                window.va ||
                function () {
                    (window.vaq = window.vaq || []).push(arguments);
                };
        </script>

        <!-- Google Tag Manager -->
        <script is:inline>
            // @ts-nocheck
            (function (w, d, s, l, i) {
                // @ts-ignore
                w[l] = w[l] || [];
                // @ts-ignore
                w[l].push({
                    "gtm.start": new Date().getTime(),
                    event: "gtm.js",
                });
                var f = d.getElementsByTagName(s)[0],
                    j = d.createElement(s),
                    dl = l != "dataLayer" ? "&l=" + l : "";
                if (j instanceof HTMLScriptElement) {
                    j.async = true;
                    j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
                }
                if (f && f.parentNode) {
                    f.parentNode.insertBefore(j, f);
                }
            })(window, document, "script", "dataLayer", "GTM-P3G8VXDF");
        </script>

        <script
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-E1FESF3403"
        ></script>
        <script is:inline>
            // @ts-nocheck
            window.dataLayer = window.dataLayer || [];
            /** @type {any[]} */
            var dataLayer = window.dataLayer;
            function gtag() {
                dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", "G-E1FESF3403");
        </script>

        <!-- ✅ THEME VARIABLES INJECTION -->
        {
            theme && (
                <style
                    is:global
                    set:html={`
                :root {
                    --c-primary: ${theme.primary} !important;
                    --c-primary-gradient: ${theme.primaryGradient ?? theme.primary} !important;
                    --c-primary-hover: ${theme.primaryHover} !important;

                    --c-bg: ${theme.bg} !important;
                    --c-surface: ${theme.surface} !important;
                    --c-surface-alt: ${theme.surfaceAlt} !important;
                    --c-border: ${theme.border} !important;

                    --c-content: ${theme.content} !important;
                    --c-content-muted: ${theme.textMuted} !important;
                    --c-content-secondary: ${theme.content} !important;

                    /* Ranking game variables */
                    --ranking-primary: ${theme.primary} !important;
                    --ranking-primary-gradient: ${theme.primaryGradient ?? theme.primary} !important;
                    --ranking-primary-alpha: ${theme.primary}33 !important;
                }
            `}
                />
            )
        }
    </head>
    <body>
        <!-- Google Tag Manager (noscript) -->
        <noscript
            ><iframe
                src="https://www.googletagmanager.com/ns.html?id=GTM-P3G8VXDF"
                height="0"
                width="0"
                style="display:none;visibility:hidden"></iframe></noscript
        >

        <IconSprite />

        <header class="site-header">
            <div class="header-container d-flex align-items-center justify-content-between w-100">
                <!-- Logo & Branding -->
                <a href="/" class="logo-brand d-flex align-items-center" aria-label="Niya BNK48 — Home">
                    <span class="logo-brand__mark" aria-hidden="true">
                        <img
                            src="/logo/WHITE.png"
                            alt="white-logo"
                            class="logo-img logo-img--on-hero"
                            width="256"
                            height="256"
                            decoding="async"
                        />
                        <img
                            src="/logo/BLACK.png"
                            alt="black-logo"
                            class="logo-img logo-img--on-bar"
                            width="256"
                            height="256"
                            decoding="async"
                        />
                    </span>
                    <span class="logo-text">Niya BNK48</span>
                </a>

                <nav class="nav-desktop align-items-center flex-wrap justify-content-end" aria-label="Main">
                    <a href="/#home" class="nav-link">Home</a>
                    <a href="/#info" class="nav-link">About Niya's</a>
                    <a href="/#social" class="nav-link">Social Media</a>
                    <a href="/#library" class="nav-link">Highlights</a>
                    <a href="/#fanclub" class="nav-link">Fanclub</a>
                    <a href="/schedule" class="nav-link nav-link--app"
                        ><i
                            class="fa-solid fa-calendar nav-icon"
                            aria-hidden="true"></i>Schedule</a
                    >
                    <a href="/planner" class="nav-link nav-link--app"
                        ><i
                            class="fa-solid fa-gamepad nav-icon"
                            aria-hidden="true"></i>Planner</a
                    >
                </nav>

                <!-- Mobile Toggle -->
                <button
                    type="button"
                    class="menu-toggle flex-column"
                    aria-label="Open menu"
                    aria-expanded="false"
                    aria-controls="site-nav-mobile"
                >
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>

            <!-- Mobile Navigation -->
            <nav id="site-nav-mobile" class="nav-mobile" aria-label="Main">
                <a href="/#home" class="nav-link-mobile d-flex align-items-center">
                    <span>Home</span>
                </a>
                <a href="/#info" class="nav-link-mobile d-flex align-items-center">
                    <span>About Niya's</span>
                </a>
                <a href="/#social" class="nav-link-mobile d-flex align-items-center">
                    <span>Social Media</span>
                </a>
                <a href="/#event" class="nav-link-mobile d-flex align-items-center">
                    <span>Events</span>
                </a>
                <a href="/#library" class="nav-link-mobile d-flex align-items-center">
                    <span>Highlights</span>
                </a>
                <a href="/#fanclub" class="nav-link-mobile d-flex align-items-center">
                    <span>Fanclub</span>
                </a>
                <hr class="nav-mobile-divider" />
                <a href="/schedule" class="nav-link-mobile d-flex align-items-center">
                    <i class="fa-solid fa-calendar nav-icon" aria-hidden="true"
                    ></i>
                    <span>Schedule</span>
                </a>
                <a href="/planner" class="nav-link-mobile d-flex align-items-center">
                    <i class="fa-solid fa-gamepad nav-icon" aria-hidden="true"
                    ></i>
                    <span>Planner</span>
                </a>
            </nav>

            <!-- Mobile Backdrop -->
            <div class="nav-backdrop"></div>
        </header>

        <main>
            <slot />
        </main>

        <footer class="mt-auto">
            <div class="collaboration text-center py-2 px-4">
                Collaboration Project<br />
                <strong class="text-nowrap">
                    Little nemo of niya × <a href="https://napheao.vercel.app/"
                        >Baby Naphaeo's</a
                    >
                </strong>
            </div>

            <div class="site-info cs-bg-dark">
                <nav class="navbar-footer">
                    <img
                        src="/logo/NAVY.png"
                        alt="Niya Logo"
                        class="footer-logo"
                        width="222"
                        height="80"
                        decoding="async"
                    />
                    <ul class="mt-4">
                        <li>
                            <a href="/cookies-policy">นโยบายเกี่ยวกับคุกกี้</a>
                        </li>
                        <li>
                            <a href="/privacy-policy">นโยบายความเป็นส่วนตัว</a>
                        </li>
                        <li>
                            <a href="/disclaimer">คำชี้แจงสำหรับแฟนไซต์</a>
                        </li>
                    </ul>
                    <ul class="mt-4">
                        <li>
                            <a
                                href="https://www.facebook.com/profile.php?id=61556940780361"
                                target="_blank"
                                rel="noopener noreferrer"
                                ><i class="fab fa-facebook"></i></a
                            >
                        </li>
                        <li>
                            <a
                                href="https://www.instagram.com/niyabnk48_thfc/"
                                target="_blank"
                                rel="noopener noreferrer"
                                ><i class="fab fa-instagram"></i></a
                            >
                        </li>
                        <li>
                            <a
                                href="https://www.youtube.com/@NiyaBNK48ThailandFanclub"
                                target="_blank"
                                rel="noopener noreferrer"
                                ><i class="fab fa-youtube"></i></a
                            >
                        </li>
                        <li>
                            <a
                                href="https://x.com/niyabnk48_thfc"
                                target="_blank"
                                rel="noopener noreferrer"
                                ><i class="fa-brands fa-x-twitter"></i></a
                            >
                        </li>
                        <li>
                            <a
                                href="https://www.tiktok.com/@niya.bnk48.thfc"
                                target="_blank"
                                rel="noopener noreferrer"
                                ><i class="fab fa-tiktok"></i></a
                            >
                        </li>
                        <li>
                            <a
                                href="https://line.me/ti/g2/YYQYpuFlsvlTQz6KyvKM7m0zmLJ39JlzdphDqA?utm_"
                                ><i class="fa-solid fa-comment-dots"></i></a
                            >
                        </li>
                    </ul>
                </nav>
            </div>

            <section class="footer-bottom text-center py-3">
                <div class="container">
                    <p class="mb-0 footer-license">
                        Original Content & Artist © by Independent Artist
                        Management (iAM).
                    </p>
                </div>
            </section>
        </footer>
    </body>
    {
        enableVercelSpeedInsights ? (
            <script is:inline>
            // @ts-nocheck
                (function () {
                    var script = document.createElement("script");
                    script.src = "/_vercel/speed-insights/script.js";
                    script.defer = true;
                    document.head.appendChild(script);
                })();
            </script>
        ) : null
    }
    <script src="../features/ui/global.js"></script>
</html>
