---
// ./components/EventCard.astro
import { formatEventDate } from "@/shared/utils/dateUtils";
import type { Event } from "@/types/event";

interface Props {
    event: Event;
    isPast?: boolean;
    variant?: "default" | "compact";
}

const { event, isPast = false, variant = "default" } = Astro.props;

function resolveImages(event: Event) {
    // Use explicit field from database if available
    const medium =
        event.image_urls?.medium ?? event.image_url ?? "/img/placeholder.jpg";
    const hover = event.image_urls?.large ?? medium;

    return { bg: medium, hover };
}

const { bg: backgroundImage, hover: hoverImage } = resolveImages(event);
const formattedDate = formatEventDate(event.date, event.end_date);

const cardClasses = [
    "event-card-wrapper",
    isPast && "is-past-event",
    variant === "compact" && "is-compact",
]
    .filter(Boolean)
    .join(" ");

const statusLabel = isPast ? "อีเวนต์ที่ผ่านมา" : "อีเวนต์ที่กำลังจะมา";
---

<article
    class={cardClasses}
    data-event-id={event.id}
    aria-label={`${statusLabel}: ${event.title}`}
>
    <!-- ภาพปกหลัก -->
    <a
        href={event.link}
        class="card-detail-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`ดูรายละเอียดเพิ่มเติม: ${event.title} (เปิดในหน้าต่างใหม่)`}
    >
        <div
            class="card-cover-img"
            style={`background-image:url('${backgroundImage}')`}
            role="img"
            aria-label={`ภาพปกอีเวนต์: ${event.title}`}
        >
        </div>

        <!-- Hover overlay — ขยายลงถึง card-info ตอน hover -->
        <div
            class="card-cover-img--hover"
            style={`background-image:url('${hoverImage}')`}
            aria-hidden="true"
        >
        </div>

        <!-- ข้อมูลอีเวนต์ -->
        <div
            class="card-info position-relative z-1"
            style="transition: background 0.2s ease;"
        >
            <div class="card-content d-flex flex-column p-4">
                <h3 class="h5 event-title fw-bold">
                    {event.title}
                </h3>

                {
                    event.location && (
                        <div class="card-meta-row d-grid gap-2 align-items-baseline">
                            <i
                                class="fa-solid fa-location-dot text-center"
                                aria-hidden="true"
                            />
                            <p class="mb-0 fw-semibold m-0">
                                <span class="visually-hidden">สถานที่: </span>
                                {event.location}
                            </p>
                        </div>
                    )
                }

                <div class="card-meta-row d-grid gap-2 align-items-baseline">
                    <i
                        class="fa-solid fa-calendar text-center"
                        aria-hidden="true"></i>
                    <p class="mb-0 fw-semibold m-0">
                        <span class="visually-hidden">วันที่: </span>{
                            formattedDate
                        }
                    </p>
                </div>

                {
                    event.live && (
                        <div class="card-meta-row d-grid gap-2 align-items-baseline">
                            <i
                                class="fa-solid fa-play text-center"
                                aria-hidden="true"
                            />
                            <p class="mb-0 fw-semibold m-0">
                                <span class="visually-hidden">ถ่ายทอดสด: </span>
                                {event.live}
                            </p>
                        </div>
                    )
                }
            </div>
        </div>
    </a>
</article>
