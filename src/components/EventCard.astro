---
import { formatEventDate } from '../lib/dateUtils';
import { getImageUrl } from '../lib/imageHelper';
import type { Event } from '../types/event';

interface Props {
  event: Event;
  isPast?: boolean;
  variant?: 'default' | 'compact';
}

const { event, isPast = false, variant = 'default' } = Astro.props;

// จัดรูปแบบวันที่
const formattedDate = formatEventDate(event.date, event.end_date);

// จัดการรูปภาพ
let backgroundImage = '/img/placeholder.jpg';
let hoverImage = '/img/placeholder.jpg';

if (event.image_urls) {
  // ข้อมูลใหม่ (มี image_urls)
  backgroundImage = getImageUrl(event.image_urls.medium) || 
                    getImageUrl(event.image_urls.small) || 
                    backgroundImage;
  hoverImage = getImageUrl(event.image_urls.large) || 
               getImageUrl(event.image_urls.medium) || 
               backgroundImage;
} else if (event.image_url) {
  // ข้อมูลเก่า (มีแค่ image_url)
  backgroundImage = event.image_url;
  hoverImage = event.image_url;
}

// CSS classes
const cardClasses = [
  'event-card',
  'carded',
  isPast && 'event-past',
  variant === 'compact' && 'event-compact'
].filter(Boolean).join(' ');
---

<article 
  class={cardClasses}
  data-event-id={event.id}
  aria-label={`${isPast ? 'อีเวนต์ที่ผ่านมา' : 'อีเวนต์ที่กำลังจะมา'}: ${event.title}`}
>
  <!-- Background image -->
  <div 
    class="card__img" 
    style={`background-image: url('${backgroundImage}');`}
    role="img"
    aria-label={`ภาพปกอีเวนต์: ${event.title}`}
  ></div>
  
  <!-- Hover overlay with larger image -->
  <a 
    href={event.link} 
    class="card_link" 
    target="_blank" 
    rel="noopener noreferrer"
    aria-label={`ดูรายละเอียดเพิ่มเติม: ${event.title} (เปิดในหน้าต่างใหม่)`}
  >
    <div 
      class="card__img--hover" 
      style={`background-image: url('${hoverImage}');`}
      aria-hidden="true"
    ></div>
  </a>
  
  <!-- Event info -->
  <div class="card__info">
    <a 
      href={event.link} 
      class="card_link" 
      target="_blank" 
      rel="noopener noreferrer"
    >
      <div class="da-sp">
        <h3 class="h5 event-title">{event.title}</h3>
        
        {event.location && (
          <div class="ct-da">
            <svg class="icon" width="16" height="16" aria-hidden="true">
              <use href="#icon-pin"></use>
            </svg>   
            <p><span class="visually-hidden">สถานที่: </span>{event.location}</p>
          </div>
        )}
        
        <div class="ct-da">
          <svg class="icon" width="16" height="16" aria-hidden="true">
            <use href="#icon-calendar"></use>
          </svg>
          <p><span class="visually-hidden">วันที่: </span>{formattedDate}</p>
        </div>
        
        {event.live && (
          <div class="ct-da text-danger">
            <svg class="icon" width="16" height="16" aria-hidden="true">
              <use href="#icon-live"></use> 
            </svg>
            <p><span class="visually-hidden">ถ่ายทอดสด: </span>{event.live}</p>
          </div>
        )}
      </div>
    </a>
  </div>
</article>

<style>
  /* เพิ่ม visually-hidden class สำหรับ screen readers */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  
  /* เพิ่ม styles เฉพาะที่จำเป็น */
  .event-title {
    margin-bottom: 0.5rem;
  }
  
  .event-card {
    /* การ์ดทั่วไปใช้ styles จาก main.css */
  }
  
  /* Compact variant สำหรับ past events */
  .event-compact {
    /* จะใช้ .event-past styles จาก schedule.css */
  }
</style>