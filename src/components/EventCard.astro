---
// ./components/EventCard.astro
import { formatEventDate } from '../lib/dateUtils';
import type { Event } from '../types/event';

interface Props {
  event: Event;
  isPast?: boolean;
  variant?: 'default' | 'compact';
}

const { event, isPast = false, variant = 'default' } = Astro.props;

// จัดรูปแบบวันที่
const formattedDate = formatEventDate(event.date, event.end_date);

// ✅ จัดการรูปภาพผ่าน URL มาร์คกิ้ง (Proxy)
let backgroundImage = '/img/placeholder.jpg';
let hoverImage = '/img/placeholder.jpg';

if (event.generated_slug) {
  // ✅ ถ้ามี slug ให้บังคับใช้ทางนี้เท่านั้น
  backgroundImage = `/dem._.mo/${event.generated_slug}?size=medium`;
} else if (event.image_urls?.medium) {
  backgroundImage = event.image_urls.medium;
} else if (event.image_url) {
  backgroundImage = event.image_url;
}

if (event.generated_slug) {
  hoverImage = `/dem._.mo/${event.generated_slug}?size=large`;
} else if (event.image_urls?.large) {
  hoverImage = event.image_urls.large;
} else if (event.image_url) {
  hoverImage = event.image_url;
}

// CSS classes
const cardClasses = [
  'event-card',
  'carded',
  isPast && 'event-past',
  variant === 'compact' && 'event-compact'
].filter(Boolean).join(' ');
---

<article
  class={cardClasses}
  data-event-id={event.id}
  aria-label={`${isPast ? "อีเวนต์ที่ผ่านมา" : "อีเวนต์ที่กำลังจะมา"}: ${event.title}`}
>
  <!-- Background image -->
  <div
    class="card__img"
    style={`background-image: url('${backgroundImage}');`}
    role="img"
    aria-label={`ภาพปกอีเวนต์: ${event.title}`}
  >
  </div>

  <!-- Hover overlay with larger image -->
  <a
    href={event.link}
    class="card_link"
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`ดูรายละเอียดเพิ่มเติม: ${event.title} (เปิดในหน้าต่างใหม่)`}
  >
    <div
      class="card__img--hover"
      style={`background-image: url('${hoverImage}');`}
      aria-hidden="true"
    >
    </div>
  </a>

  <!-- Event info -->
  <div class="card__info">
    <a
      href={event.link}
      class="card_link"
      target="_blank"
      rel="noopener noreferrer"
    >
      <div class="da-sp">
        <h3 class="h5 event-title">{event.title}</h3>

        {
          event.location && (
            <div class="ct-da">
              <svg class="icon" width="16" height="16" aria-hidden="true">
                <use href="#icon-pin" />
              </svg>
              <p>
                <span class="visually-hidden">สถานที่: </span>
                {event.location}
              </p>
            </div>
          )
        }

        <div class="ct-da">
          <svg class="icon" width="16" height="16" aria-hidden="true">
            <use href="#icon-calendar"></use>
          </svg>
          <p><span class="visually-hidden">วันที่: </span>{formattedDate}</p>
        </div>

        {
          event.live && (
            <div class="ct-da text-danger">
              <svg class="icon" width="16" height="16" aria-hidden="true">
                <use href="#icon-live" />
              </svg>
              <p>
                <span class="visually-hidden">ถ่ายทอดสด: </span>
                {event.live}
              </p>
            </div>
          )
        }
      </div>
    </a>
  </div>
</article>