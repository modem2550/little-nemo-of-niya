---
import type { Event as ProjectEvent } from "@/types/event";

interface Props {
    event: ProjectEvent; // Adjust to the exact type used if possible, but Event is typically what you have. Wait, in page mapping it's just 'any' or the config type.
    type: "planner" | "fan_project" | "ranking";
}

const { event, type } = Astro.props as Props;

// Determine properties based on type
const href =
    type === "ranking"
        ? `/ranking/${event.slug}`
        : event.features?.planner?.href || `/planner/${event.slug}`;

const image =
    type === "ranking"
        ? event.features?.ranking?.listingImage
        : event.features?.planner?.listingImage ??
          event.features?.planner?.heroImage;

const title = event.name;

const description =
    type === "ranking"
        ? event.features?.ranking?.description
        : event.features?.planner?.description;

const primaryColor = event.primaryColor;

// Badges and icons
const getBadgeContent = () => {
    switch (type) {
        case "planner":
            return `<i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i> <span>Planner</span>`;
        case "fan_project":
            return `<i class="fa-solid fa-heart" aria-hidden="true"></i> <span>Niya Level Up</span>`;
        case "ranking":
            return `<i class="fa-solid fa-gamepad" aria-hidden="true"></i> <span>${event.features?.ranking?.rounds ?? 0} รอบ</span>`;
    }
};

const ctaText =
    type === "planner"
        ? "เปิดแพลนเนอร์"
        : type === "fan_project"
          ? "เปิดดูรายละเอียด"
          : "เล่นเกม";

const showOfficialLink = type === "planner" && event.features?.planner?.officialLink;
---

<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
    <div class="col d-flex justify-content-center">
        <article
            class="planner-card__article d-flex flex-column h-100 overflow-hidden"
            style={`--planner-accent: ${primaryColor};`}
        >
            <a
                class="planner-card__media"
                href={href}
                aria-label={`Open ${type === 'ranking' ? 'ranking game' : 'planner'} for ${title}`}
            >
                {image && (
                    <img
                        src={image}
                        alt={title}
                        width="960"
                        height="540"
                        loading="lazy"
                        decoding="async"
                    />
                )}
                <span class="planner-card__badge" aria-hidden="false" set:html={getBadgeContent()}></span>
            </a>
            <div class="planner-card__body d-flex flex-column flex-grow-1">
                <h3 class="h6 planner-card__title">
                    <a href={href}>{title}</a>
                </h3>
                <p class="planner-card__desc">{description}</p>
                <div class="planner-card__actions d-flex flex-wrap align-items-center">
                    <a
                        class={`btn planner-card__cta ${type === 'ranking' ? 'btn-sm btn-primary btn-rounded fw-700' : ''}`}
                        href={href}
                    >
                        {ctaText}
                        <i class="fa-solid fa-arrow-right arrow-icon ms-1" aria-hidden="true" />
                    </a>
                    {showOfficialLink && (
                        <a
                            class="planner-card__official d-inline-flex align-items-center position-relative"
                            href={event.features?.planner?.officialLink}
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            ข้อมูลทางการ
                            <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true" />
                            <span class="sr-only">(opens in new window)</span>
                        </a>
                    )}
                </div>
            </div>
        </article>
    </div>
</div>
