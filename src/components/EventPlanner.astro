---
// src/components/EventPlanner.astro
import '../styles/event.css';
import type { ActivityConfig, DayConfig, PriceConfig, ScheduleEntry } from '../lib/planner';

interface MemberRow {
    id: number;
    name: string;
    brand: string;
    gen: string;
    team: string;
    profile_image_url?: string | null;
}

interface Props {
    eventSlug:    string;
    eventName:    string;
    pageTitle?:   string;
    officialLink: string;
    storageKey:   string;
    heroImage:    string;
    primaryColor: string;
    primaryHover: string;
    prices:       PriceConfig;
    days:         DayConfig[];
    activities:   ActivityConfig[];
    members:      MemberRow[];
    schedule:     ScheduleEntry[];
}

const {
    eventName, officialLink, storageKey, heroImage,
    prices, days, activities, members, schedule,
} = Astro.props;

const TEAM_COLOR: Record<string, string> = {
    "Team BIII": "#cb96c2",
    "Team NV":   "#cb96c2",
    "Team C":    "#3CC2B1",
    "Trainee":   "#93001d",
};

const cfg = JSON.stringify({ activities, days, storageKey, schedule, prices });
---

    <div class="sf-hero" style={{ backgroundImage: `url('${heroImage}')`, backgroundPosition: 'center', backgroundSize: 'cover', backgroundRepeat: 'no-repeat', padding: '110px 20px 20px'}}>
        <div class="container pb-3 text-center">
            <p class="fw-bold h5 text-white-muted mb-1;" style="color: color-mix(in srgb, var(--c-text-muted) 50%, var(--c-surface));">BNK48 & CGM48</p>
            <h2 class="h-sec display-6 fw-bolder mb-0" style="color: var(--c-primary);">{eventName}</h2>
            <span class="text-white-muted" style="font-size:13px; color: color-mix(in srgb, var(--c-text-muted) 50%, var(--c-surface));">รายละเอียด&nbsp;:&nbsp;
                <a href={officialLink} style="color:var(--c-primary)">BNK48 & CGM48 Official</a>
            </span>
        </div>
    </div>

    <!-- TABS -->
    <div class="container px-3">
        <div class="sf-tabs-wrap">
            <div class="sf-tabs d-flex justify-content-center overflow-auto">
                {[
                    { id: 'members',      icon: 'fa-user-group',  label: 'Members' },
                    { id: 'planner',      icon: 'fa-calendar',    label: 'Planner' },
                    { id: 'happening',    icon: 'fa-clock',       label: 'Now' },
                    { id: 'summary',      icon: 'fa-list-check',  label: 'Summary' },
                ].map(({ id, icon, label }) => (
                    <button class={`sf-tab${id === 'members' ? ' active' : ''}`} data-tab={id}>
                        <i class={`fa-solid ${icon}`}></i>{label}
                        {id === 'happening' && <span class="tab-badge tab-badge--live" id="nowBadge" style="display:none">LIVE</span>}
                        {id === 'summary'   && <span class="tab-badge" id="summaryBadge" style="display:none">0</span>}
                    </button>
                ))}
            </div>
        </div>
    </div>

    <!-- TAB: MEMBERS -->
    <div class="sf-panel active" id="panel-members">
        <div class="sf-section mx-auto">
            <div class="filter-bar mb-4 mx-auto">
                <div class="row g-2" id="mBrandGroup">
                    {[
                        { v: 'all',   label: 'All',   cls: 'ftab--all active' },
                        { v: 'BNK48', label: 'BNK48', cls: 'ftab--bnk' },
                        { v: 'CGM48', label: 'CGM48', cls: 'ftab--cgm' },
                    ].map(({ v, label, cls }) => (
                        <div class="col-4">
                            <button class={`ftab ${cls} w-100`} data-mf="brand" data-mv={v}>{label}</button>
                        </div>
                    ))}
                </div>
                <hr class="filter-divider" />
                <div id="mGenGroup"></div>
                <hr class="filter-divider d-none" id="mGenDivider" />
                <div id="mTeamGroup"></div>
            </div>
            <div class="member-cards-grid" id="memberCardsGrid">
                {members.map((m) => {
                    const isBNK = m.brand === "BNK48";
                    const tc = TEAM_COLOR[m.team] ?? "#9b90b8";
                    return (
                        <div class="member-card"
                            data-name={m.name} data-brand={m.brand}
                            data-gen={m.gen} data-team={m.team}
                            data-img={m.profile_image_url ?? ""}>
                            <div class="member-card__img-wrap" style={`border-color:${tc}`}>
                                {m.profile_image_url ? (
                                    <img src={m.profile_image_url} alt={m.name}
                                        class="member-card__img" loading="lazy"
                                        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                ) : null}
                                <div class={`member-card__fallback ${isBNK ? "av--bnk" : "av--cgm"}`}
                                    style={m.profile_image_url ? "display:none" : ""}>
                                    {m.name[0]}
                                </div>
                            </div>
                            <div class="member-card__info p-2">
                                <div class="member-card__name">{m.name}</div>
                                <div class="d-flex align-items-center gap-1 mb-1">
                                    <span class={`brand-badge ${isBNK ? "bb--bnk" : "bb--cgm"}`}>{m.brand}</span>
                                    <span class="gen-text">{m.gen}</span>
                                </div>
                                <div class="member-card__team" style={`color:${tc}`}>{m.team}</div>
                            </div>
                            <button class="member-card__select-btn" data-name={m.name}
                                onclick="toggleFromMembersTab(this)" type="button">
                                <i class="fa-solid fa-circle-plus"></i> Add to Planner
                            </button>
                        </div>
                    );
                })}
            </div>
        </div>
    </div>

    <!-- TAB: PLANNER -->
    <div class="sf-panel" id="panel-planner">
        <div class="sf-section mx-auto">
            <div class="panel-empty text-center py-5 flex-column align-items-center" id="plannerEmpty">
                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor"
                    viewBox="0 0 16 16" style="opacity:.3" class="mb-3">
                    <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a6 6 0 0 0-1.23-.247A7 7 0 0 0 5 9c-4 0-5 3-5 4q0 1 1 1h4.216A2.24 2.24 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 10A5.5 5.5 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4"/>
                </svg>
                <p class="fw-bold mb-1" style="color:var(--c-content)">ยังไม่ได้เลือก Member</p>
                <p class="mb-3" style="font-size:13px;color:#b0a8c4">ไปที่ Tab Members เพื่อเลือก Member ที่ต้องการ</p>
                <button class="btn-outline-sf" onclick="APP.switchTab('members')">ไปที่ Members</button>
            </div>
            <div id="plannerContent" style="display:none">
                <div class="filter-bar mx-auto">
                    <div class="row g-2 mb-0" id="dayFilterRow">
                        <div class="col-6 col-sm-3">
                            <button class="day-ftab active w-100" data-day="all">All Days</button>
                        </div>
                        {days.map((d) => (
                            <div class="col-6 col-sm-3">
                                <button class={`day-ftab day-ftab--${d.key} w-100`} data-day={d.key}>
                                    {d.label}
                                </button>
                            </div>
                        ))}
                    </div>
                    <hr class="filter-divider" />
                    <div class="row g-2 align-items-stretch mb-3" id="actNameFilterRow"></div>
                    <div class="d-flex flex-wrap gap-2 mb-3" id="selectedMembersStrip"></div>
                    <div id="scheduleBlocks"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- TAB: HAPPENING NOW -->
    <div class="sf-panel" id="panel-happening">
        <div class="sf-section filter-bar mb-4 mx-auto">
             <div class="now-section-label now-section-label--live" style="justify-content: center; font-size:var(--fs-body);">Live Happening Activities</div>
            <div id="nowContent"></div>
        </div>
    </div>

    <!-- TAB: SUMMARY -->
    <div class="sf-panel" id="panel-summary">
        <div class="sf-section mx-auto">
            <div class="panel-empty text-center py-5 flex-column align-items-center" id="summaryEmpty">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor"
                    viewBox="0 0 16 16" style="opacity:.3" class="mb-3">
                    <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm15 2h-4v3h4zm0 4h-4v3h4zm0 4h-4v3h3a1 1 0 0 0 1-1zm-5 3v-3H6v3zm-5 0v-3H1v2a1 1 0 0 0 1 1zm-4-4h4V8H1zm0-4h4V4H1zm5-3v3h4V4zm4 4H6v3h4z"/>
                </svg>
                <p class="fw-bold mb-1" style="font-size:16px;color:var(--c-content)">ยังไม่มี Round ที่เลือก</p>
                <p class="mb-3" style="font-size:13px;color:#b0a8c4">กลับไปที่ Planner เพื่อเลือก Round</p>
                <button class="btn-outline-sf" onclick="APP.switchTab('planner')">ไปที่ Planner</button>
            </div>
            <div id="summaryContent" style="display:none">
                <div class="stat-grid mb-3" id="statGrid"></div>
                <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
                    <div class="d-flex gap-2 flex-wrap flex-1" id="summaryDayTabs">
                        <button class="day-tab active" data-day="all">All Days</button>
                        {days.map((d) => (
                            <button class={`day-tab day-tab--${d.key}`} data-day={d.key}>{d.short}</button>
                        ))}
                    </div>
                    <div class="d-flex gap-2 align-items-center flex-shrink-0">
                        <!-- Export Recap button -->
                        <button class="btn-outline-sf btn-export-recap" id="exportRecapBtn" onclick="APP.exportRecap()">
                            <i class="fa-solid fa-image"></i> Export Recap
                        </button>
                        <div class="position-relative" id="sortDropdownWrap">
                            <button class="sort-toggle-btn" id="sortToggleBtn" onclick="APP.toggleSortMenu()">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M3.5 3.5a.5.5 0 0 0-1 0v8.793l-1.146-1.147a.5.5 0 0 0-.708.708l2 1.999.007.007a.497.497 0 0 0 .7-.006l2-2a.5.5 0 0 0-.707-.708L3.5 12.293zm4 .5a.5.5 0 0 1 0-1h1a.5.5 0 0 1 0 1zm0 3a.5.5 0 0 1 0-1h3a.5.5 0 0 1 0 1zm0 3a.5.5 0 0 1 0-1h5a.5.5 0 0 1 0 1zM7 12.5a.5.5 0 0 0 .5.5h7a.5.5 0 0 0 0-1h-7a.5.5 0 0 0-.5.5"/>
                                </svg>
                                Sort <span class="sort-active-label" id="sortActiveLabel">Day Time ↑</span>
                            </button>
                            <div class="sort-menu" id="sortMenu"></div>
                        </div>
                    </div>
                </div>
                <div class="table-responsive rounded mb-3">
                    <table class="sf-table w-100">
                        <thead>
                            <tr>
                                <th>Member</th><th>Activity</th><th>Day</th>
                                <th>Time</th><th>Round</th><th>Price</th>
                            </tr>
                        </thead>
                        <tbody id="summaryTbody"></tbody>
                    </table>
                </div>
                <div class="summary-footer" id="summaryFooter"></div>
                <div class="d-flex gap-2 flex-wrap mt-3">
                    <button class="btn-action btn-action--danger" onclick="APP.resetAll()">
                        <i class="fa-solid fa-rotate-left"></i>Reset All
                    </button>
                </div>
                <div class="sf-disclaimer mt-4 pb-0">
                    <div class="mx-auto">
                        <div class="sf-disclaimer__title">การคำนวณค่าใช้จ่ายใน Planner อ้างอิงจากราคาต่อรายการดังนี้</div>
                        <ul class="sf-disclaimer__list">
                            <li>Digital Event Ticket — 250 Bath per Ticket</li>
                            <li>ฮับขวัญได้(ด้าย)ไหมเจ้า? — 200 THB per Set</li>
                            <li>ค่าใช้จ่ายที่แสดงเป็นเพียงการประมาณเพื่อช่วยวางแผน และไม่รวมสินค้า Hachi Cha ( <a href="https://www.facebook.com/share/p/1Dd4vvEwzx/">สามารถตรวจสอบราคาได้ที่ <strong>HachiCha</strong></a> ) และ Merchandise </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- DISCLAIMER -->
    <div class="sf-disclaimer">
        <hr class="filter-divider">
        <div class="sf-section mx-auto">
            <div class="sf-disclaimer__title">
                <i class="fa-solid fa-circle-info"></i> หมายเหตุ
            </div>
            <ul class="sf-disclaimer__list">
                <li>ตารางกิจกรรมและรูปแบบกิจกรรมอาจมีการเปลี่ยนแปลงได้ตามความเหมาะสม</li>
                <li>กิจกรรมอาจมีการปรับรูปแบบหรือเลื่อนเวลาตามความเหมาะสม โปรดติดตามข้อมูลจาก <a href={officialLink} target="_blank"><strong>BNK48 & CGM48 Official</strong></a></li>
                <li>เวลาที่แสดงใช้เพื่อประกอบการวางแผนเท่านั้น <strong>ผู้ใช้งานควรบริหารการใช้บัตรกิจกรรมด้วยตนเอง</strong></li>
                <li>ข้อมูลการวางแผนจะถูกบันทึกไว้ในเบราว์เซอร์ของผู้ใช้งาน (localStorage) และอาจต้องปรับแก้ด้วยตนเองหากมีการเปลี่ยนแปลงข้อมูล</li>
            </ul>
            <br />
            <div class="sf-disclaimer__title">
                <i class="fa-solid fa-circle-info"></i> <strong>Disclaimer</strong>
            </div>
            <ul class="sf-disclaimer__list">
                <li>เว็บไซต์นี้จัดทำโดยแฟนคลับเพื่อช่วยวางแผนการเข้าร่วมกิจกรรมเท่านั้น ไม่มีความเกี่ยวข้องหรือการรับรองอย่างเป็นทางการจาก BNK48 หรือ CGM48 หรือหน่วยงานที่เกี่ยวข้อง หากพบปัญหาสามารถแจ้งได้ที่ — <a href="https://www.facebook.com/profile.php?id=61556940780361"><strong>little nemo of Niya</strong> (Niya BNK48 Thailand Fanclub)</a> ทุกช่องทาง</li>
            </ul>
        </div>
    </div>

<div class="sf-toast" id="sfToast"></div>

<!-- Hidden canvas for Export Recap -->
<canvas id="recapCanvas" style="display:none"></canvas>

<script define:vars={{ cfg }}>
    // ── Bootstrap ────────────────────────────────────────────────────────────
    const { activities: ACTIVITIES, days: DAYS, storageKey: STORAGE_KEY,
            schedule: SCHEDULE, prices: PRICES } = JSON.parse(cfg);

    // ── Schedule map ─────────────────────────────────────────────────────────
    const MEMBER_SCHEDULE_MAP = new Map();
    for (const { activitySlug, slots } of SCHEDULE) {
        const actName = ACTIVITIES.find((a) => a.slug === activitySlug)?.name ?? activitySlug;
        for (const { day, time, members, note } of slots) {
            const slotId = `${activitySlug}__${day}__${time}`;
            for (const m of members) {
                const rows = MEMBER_SCHEDULE_MAP.get(m) ?? [];
                rows.push({
                    member_name:      m,
                    activity_slug:    activitySlug,
                    activity_name:    actName,
                    activity_icon:    "",
                    tickets_required: null,
                    is_merch:         false,
                    slot_id:          slotId,
                    day,
                    time_range:       time,
                    slot_members:     members,
                    note:             note ?? null,
                });
                MEMBER_SCHEDULE_MAP.set(m, rows);
            }
        }
    }

    // ── Full schedule index (day → time → activity → members) ─────────────────
    // Used by Happening Now
    const FULL_SCHEDULE = {}; // day → [ { time, actSlug, actName, members, note } ]
    for (const { activitySlug, slots } of SCHEDULE) {
        const actName = ACTIVITIES.find((a) => a.slug === activitySlug)?.name ?? activitySlug;
        for (const { day, time, members, note } of slots) {
            FULL_SCHEDULE[day] ??= [];
            FULL_SCHEDULE[day].push({ time, actSlug: activitySlug, actName, members, note });
        }
    }

    const DAY_SHORT = Object.fromEntries(DAYS.map((d) => [d.key, d.short]));
    const DAY_KEYS  = DAYS.map((d) => d.key);
    const DAY_ORDER = Object.fromEntries(DAYS.map((d, i) => [d.key, i]));

    // ── Helpers ──────────────────────────────────────────────────────────────
    function findAct(name, slug) {
        const n = name ?? "", s = slug ?? "";
        return ACTIVITIES.find((a) =>
            a.slug === s ||
            (a.match ?? []).some((k) =>
                n.toLowerCase().includes(k.toLowerCase()) ||
                s.toLowerCase().includes(k.toLowerCase())
            )
        ) ?? { icon: "fa-solid fa-ticket", color: "#8b5cf6", desc: "", slug: s };
    }

    function actType(name, slug) {
        return findAct(name, slug).type ?? "normal";
    }

    function ticketsFor(type, name, slug, override) {
        if (type === "merch" || type === "hub") return 0;
        return override ?? findAct(name, slug).tickets ?? 1;
    }

    function priceFor(type, name, slug, override) {
        if (type === "merch") return 0;
        if (type === "hub")   return PRICES.hub;
        return ticketsFor(type, name, slug, override) * PRICES.ticket;
    }

    // Parse "HH:MM–HH:MM" → { startMin, endMin }
    function parseTimeRange(range) {
        const parts = range.replace(/–|-/g, "–").split("–");
        const toMin = (s) => {
            const [h, m] = s.trim().split(":").map(Number);
            return h * 60 + (m || 0);
        };
        return { startMin: toMin(parts[0]), endMin: toMin(parts[1] ?? parts[0]) };
    }

    // ── Bangkok time helpers ─────────────────────────────────────────────────
    function bkkNow() {
        return new Date(new Date().toLocaleString("en-US", { timeZone: "Asia/Bangkok" }));
    }

    function nowMinutes() {
        const b = bkkNow();
        return b.getHours() * 60 + b.getMinutes();
    }

    // ── Detect today's day key from Bangkok date ──────────────────────────────
    function detectTodayKey() {
        const b = bkkNow();
        const y = b.getFullYear();
        const m = String(b.getMonth() + 1).padStart(2, "0");
        const d = String(b.getDate()).padStart(2, "0");
        const todayStr = `${y}-${m}-${d}`;

        const found = DAYS.find((day) => day.date === todayStr);
        return found?.key ?? null;
    }

    function updateNowClock() {
        const b = bkkNow();
        const hh = String(b.getHours()).padStart(2, "0");
        const mm = String(b.getMinutes()).padStart(2, "0");
        const el = document.getElementById("nowClock");
        if (el) el.textContent = `${hh}:${mm}`;

        const dayNames = ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"];
        const monthNames = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
        const meta = document.getElementById("nowClockMeta");
        if (meta) {
            meta.textContent = `${dayNames[b.getDay()]} ${b.getDate()} ${monthNames[b.getMonth()]} ${b.getFullYear()}`;
        }
    }

    updateNowClock();

    // ── State ────────────────────────────────────────────────────────────────
    const state = {
        selectedMembers: new Set(),
        memberCache:     new Map(),
        cart:            new Map(),
        plannerDay:      "all",
        plannerActNames: new Set(),
        summaryDay:      "all",
        summarySort:     "day",
        summarySortDir:  "asc",
        mFilterBrand:    "all",
        mFilterGen:      "all",
        mFilterTeam:     "all",
    };

    // ── Storage ──────────────────────────────────────────────────────────────
    const STATE_KEYS = ["plannerDay","summaryDay","summarySort","summarySortDir",
                        "mFilterBrand","mFilterGen","mFilterTeam"];

    function saveToStorage() {
        try {
            localStorage.setItem(STORAGE_KEY, JSON.stringify({
                ...Object.fromEntries(STATE_KEYS.map((k) => [k, state[k]])),
                cart:            [...state.cart.entries()].map(([sid, item]) => ({ sid, item })),
                selectedMembers: [...state.selectedMembers],
                plannerActNames: [...state.plannerActNames],
            }));
        } catch {}
    }

    // ── Icons ────────────────────────────────────────────────────────────────
    const ICON_ADD   = `<i class="fa-solid fa-circle-plus"></i>`;
    const ICON_CHECK = `<i class="fa-solid fa-check"></i>`;
    const ICON_DEL   = `<i class="fa-solid fa-minus"></i>`;

    const memberCard  = (n) => document.querySelector(`.member-card[data-name="${CSS.escape(n)}"]`);
    const memberImg   = (n) => memberCard(n)?.dataset.img ?? "";
    const memberMeta  = (n) => ({ brand: memberCard(n)?.dataset.brand ?? "CGM48" });

    function showToast(msg) {
        const t = document.getElementById("sfToast");
        t.textContent = msg; t.classList.add("show");
        setTimeout(() => t.classList.remove("show"), 2500);
    }

    function fetchSchedule(name) {
        if (state.memberCache.has(name)) return state.memberCache.get(name);
        const rows = MEMBER_SCHEDULE_MAP.get(name) ?? [];
        state.memberCache.set(name, rows);
        return rows;
    }

    // ── Cart ─────────────────────────────────────────────────────────────────
    function setRounds(item, newRounds) {
        if (newRounds <= 0) {
            state.cart.delete(item.sid);
        } else {
            const existing = state.cart.get(item.sid);
            state.cart.set(item.sid, { ...item, rounds: newRounds });
            if (existing) {
                const input = document.querySelector(`.ticket-qty[data-sid="${item.sid}"]`);
                if (input) {
                    input.value = String(newRounds);
                    input.previousElementSibling?.toggleAttribute("disabled", newRounds === 0);
                    input.closest(".slot-row")?.classList.toggle("has-rounds", newRounds > 0);
                }
                updateSummaryBadge();
                saveToStorage();
                return;
            }
        }
        renderPlannerSchedule();
        updateSummaryBadge();
        saveToStorage();
    }

    // ── Tabs ─────────────────────────────────────────────────────────────────
    function switchTab(tabId) {
        document.querySelectorAll(".sf-tab").forEach((t) => t.classList.remove("active"));
        document.querySelectorAll(".sf-panel").forEach((p) => p.classList.remove("active"));
        document.querySelector(`.sf-tab[data-tab="${tabId}"]`)?.classList.add("active");
        document.getElementById(`panel-${tabId}`)?.classList.add("active");
        if (tabId === "summary")   renderSummaryTab();
        if (tabId === "happening") renderHappeningNow();
    }
    document.querySelectorAll(".sf-tab").forEach((btn) =>
        btn.addEventListener("click", () => switchTab(btn.dataset.tab))
    );

    // ── Member filter ─────────────────────────────────────────────────────────
    function buildMemberPageChips() {
        const cards = Array.from(document.querySelectorAll(".member-card"));
        const gens = new Set(), teams = new Set();
        cards.forEach((c) => {
            if (state.mFilterBrand === "all" || c.dataset.brand === state.mFilterBrand) {
                if (c.dataset.gen)  gens.add(c.dataset.gen);
                if (c.dataset.team) teams.add(c.dataset.team);
            }
        });
        const genOrder  = ["Gen 2","Gen 3","Gen 4","Gen 5","Gen 6","Unknown"];
        const teamOrder = ["Team BIII","Team NV","Team C","Trainee"];
        const sGens  = [...gens].sort((a,b)  => genOrder.indexOf(a)  - genOrder.indexOf(b));
        const sTeams = [...teams].sort((a,b) => teamOrder.indexOf(a) - teamOrder.indexOf(b));

        function renderChips(id, items, allLabel, cur, fk) {
            const el = document.getElementById(id);
            if (!items.length) { el.innerHTML = ""; return; }
            const all = [{ v: "all", label: allLabel }, ...items.map((v) => ({ v, label: v }))];
            el.innerHTML = `<div class="row g-2">${all.map(({ v, label }) =>
                `<div class="col-auto col-sm-2"><button class="ftab chip ${cur === v ? "active" : ""} w-100" data-mf="${fk}" data-mv="${v}">${label}</button></div>`
            ).join("")}</div>`;
        }
        renderChips("mGenGroup",  sGens,  "All Gen",  state.mFilterGen,  "gen");
        renderChips("mTeamGroup", sTeams, "All Team", state.mFilterTeam, "team");
        document.getElementById("mGenDivider")?.classList.toggle("d-none", !(sGens.length && sTeams.length));

        document.querySelectorAll("#mGenGroup .ftab, #mTeamGroup .ftab").forEach((btn) =>
            btn.addEventListener("click", () => {
                const type = btn.dataset.mf, val = btn.dataset.mv;
                if (type === "gen") { state.mFilterGen = val; state.mFilterTeam = "all"; }
                else state.mFilterTeam = val;
                buildMemberPageChips();
                applyMemberCardFilter();
                saveToStorage();
            })
        );
    }

    function applyMemberCardFilter() {
        document.querySelectorAll(".member-card").forEach((c) => {
            const ok = (state.mFilterBrand === "all" || c.dataset.brand === state.mFilterBrand)
                    && (state.mFilterGen   === "all" || c.dataset.gen   === state.mFilterGen)
                    && (state.mFilterTeam  === "all" || c.dataset.team  === state.mFilterTeam);
            c.toggleAttribute("data-hidden", !ok);
        });
    }

    document.getElementById("mBrandGroup")?.addEventListener("click", (e) => {
        const btn = e.target.closest(".ftab");
        if (!btn) return;
        document.querySelectorAll("#mBrandGroup .ftab").forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        state.mFilterBrand = btn.dataset.mv;
        state.mFilterGen   = "all";
        state.mFilterTeam  = "all";
        buildMemberPageChips();
        applyMemberCardFilter();
        saveToStorage();
    });

    buildMemberPageChips();

    // ── Planner day filter ────────────────────────────────────────────────────
    document.getElementById("dayFilterRow")?.addEventListener("click", (e) => {
        const btn = e.target.closest(".day-ftab");
        if (!btn) return;
        document.querySelectorAll("#dayFilterRow .day-ftab").forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        state.plannerDay = btn.dataset.day;
        renderPlannerSchedule();
        saveToStorage();
    });

    // ── Activity name filter ──────────────────────────────────────────────────
    function buildActNameFilter() {
        const allNames = new Map();
        state.selectedMembers.forEach((name) =>
            (state.memberCache.get(name) ?? [])
                .filter((r) => r.member_name === name)
                .forEach((r) => { if (!allNames.has(r.activity_slug)) allNames.set(r.activity_slug, r.activity_name); })
        );
        state.plannerActNames.forEach((slug) => { if (!allNames.has(slug)) state.plannerActNames.delete(slug); });
        const container = document.getElementById("actNameFilterRow");
        if (!allNames.size) { container.innerHTML = ""; return; }
        container.innerHTML = [...allNames.entries()].map(([slug, name]) => {
            const cfg = findAct(name, slug);
            return `<div class="col-3 d-flex"><button class="ftab chip act-chip ${state.plannerActNames.has(slug) ? "active" : ""} w-100 h-100" style="--chip-color:${cfg.color}" data-act-name="${slug}"><i class="${cfg.icon}" style="font-size:14px"></i><span>${name}</span></button></div>`;
        }).join("");
    }

    document.getElementById("actNameFilterRow")?.addEventListener("click", (e) => {
        const btn = e.target.closest("[data-act-name]");
        if (!btn) return;
        const slug = btn.dataset.actName;
        const alreadyActive = state.plannerActNames.has(slug);
        state.plannerActNames.clear();
        document.querySelectorAll("#actNameFilterRow [data-act-name]").forEach((b) => b.classList.remove("active"));
        if (!alreadyActive) { state.plannerActNames.add(slug); btn.classList.add("active"); }
        renderPlannerSchedule();
        saveToStorage();
    });

    // ── Member selection ──────────────────────────────────────────────────────
    function toggleMember(btn) {
        const name = btn.dataset.name;
        if (state.selectedMembers.has(name)) {
            state.selectedMembers.delete(name);
            if (!state.selectedMembers.size) state.plannerActNames.clear();
            btn.classList.remove("active");
            btn.innerHTML = ICON_ADD + " Add to Planner";
            state.cart.forEach((_, sid) => { if (sid.endsWith(`__${name}`)) state.cart.delete(sid); });
        } else {
            state.selectedMembers.add(name);
            btn.classList.add("active");
            btn.innerHTML = ICON_CHECK + " Added";
            fetchSchedule(name);
        }
        renderSelectedMembersStrip();
        renderPlannerSchedule();
        updateSummaryBadge();
        saveToStorage();
    }

    function removeMemberFromPlanner(name) {
        state.selectedMembers.delete(name);
        state.cart.forEach((_, sid) => { if (sid.endsWith(`__${name}`)) state.cart.delete(sid); });
        const cardBtn = document.querySelector(`.member-card__select-btn[data-name="${CSS.escape(name)}"]`);
        if (cardBtn) { cardBtn.classList.remove("active"); cardBtn.innerHTML = ICON_ADD + " Add to Planner"; }
        renderSelectedMembersStrip();
        renderPlannerSchedule();
        updateSummaryBadge();
        saveToStorage();
    }

    function renderSelectedMembersStrip() {
        document.getElementById("selectedMembersStrip").innerHTML = [...state.selectedMembers].map((name) => {
            const img = memberImg(name);
            const imgEl = img
                ? `<img src="${img}" alt="${name}" class="sel-pill__img" onerror="this.style.display='none'">`
                : `<span class="sel-pill__img" style="display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:900;background:rgba(255,255,255,.25)">${name[0]}</span>`;
            return `<div class="sel-pill">${imgEl}${name}<button class="sel-pill__rm" onclick="APP.removeMember('${name}')" title="Remove">${ICON_DEL}</button></div>`;
        }).join("");
    }

    // ── Planner render ────────────────────────────────────────────────────────
    function buildGrouped() {
        const grouped = {};
        state.selectedMembers.forEach((name) =>
            (state.memberCache.get(name) ?? [])
                .filter((r) => r.member_name === name)
                .forEach((r) => {
                    if (state.plannerActNames.size > 0 && !state.plannerActNames.has(r.activity_slug)) return;
                    const k = String(r.slot_id);
                    grouped[r.day] ??= {};
                    grouped[r.day][r.activity_slug] ??= {};
                    grouped[r.day][r.activity_slug][k] ??= { row: { ...r, forMember: name }, members: [] };
                    const e = grouped[r.day][r.activity_slug][k];
                    if (!e.members.includes(name)) e.members.push(name);
                })
        );
        return grouped;
    }

    function buildSlotRowHTML(actSlug, slotId, day, entry, firstRow, aType) {
        const memberName = entry.members[0]; // representative (คนแรก)
        const sid = `${actSlug}__${slotId}__${memberName}`;
        const qty = state.cart.get(sid)?.rounds ?? 0;
        const cfg = findAct(firstRow.activity_name, actSlug);

        const p = [
            `'${sid}'`, `'${actSlug}'`, `'${slotId}'`, `'${memberName}'`,
            `'${encodeURIComponent(firstRow.activity_name)}'`, `'${day}'`,
            `'${encodeURIComponent(entry.row.time_range)}'`, `'${encodeURIComponent(aType)}'`,
            firstRow.tickets_required ?? "null",
            `'${encodeURIComponent((entry.row.slot_members ?? []).join(","))}'`,
        ].join(",");

        // Badge เฉพาะ member ที่อยู่ใน entry.members
        const memberBadges = entry.members.map(m =>
            `<span style="background:var(--c-primary);color:#fff;border-radius:100px;padding:1px 8px;font-size:11px;font-weight:700">${m}</span>`
        ).join("");

        return `<div class="slot-row ${qty > 0 ? "has-rounds" : ""}" style="--act-color:${cfg.color}">
                    <div class="slot-left">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <span class="slot-time">${entry.row.time_range}</span>
                            ${memberBadges}
                        </div>
                        ${entry.row.note ? `<div class="act-warn act-warn--warn slot-note"><i class="fa-solid fa-triangle-exclamation"></i> ${entry.row.note}</div>` : ""}
                    </div>
                    <div class="slot-right">
                        <div class="ticket-form">
                            <button type="button" class="ticket-btn" ${qty === 0 ? "disabled" : ""} onclick="APP.changeRounds(${p},-1)"><i class="fa-solid fa-minus"></i></button>
                            <input type="number" class="ticket-qty" value="${qty}" min="0" inputmode="numeric"
                                data-sid="${sid}" data-actslug="${actSlug}" data-slotid="${slotId}"
                                data-member="${memberName}" data-actname="${encodeURIComponent(firstRow.activity_name)}"
                                data-day="${day}" data-time="${encodeURIComponent(entry.row.time_range)}"
                                data-atype="${encodeURIComponent(aType)}"
                                data-ticketsreq="${firstRow.tickets_required ?? "null"}"
                                data-slotmembers="${encodeURIComponent((entry.row.slot_members ?? []).join(","))}"
                                onchange="APP.setRoundsFromInput(this)">
                            <button type="button" class="ticket-btn" onclick="APP.changeRounds(${p},1)"><i class="fa-solid fa-plus"></i></button>
                        </div>
                    </div>
                </div>`;
    }

    function buildActBlockHTML(actSlug, slots, day) {
        const firstRow = Object.values(slots)[0].row;
        const aType    = actType(firstRow.activity_name, actSlug);
        const cfg      = findAct(firstRow.activity_name, actSlug);

        let infoHTML = "";
        if (cfg.desc || cfg.warning) {
            const warnIcon = cfg.warningLevel === "danger"
                ? `<i class="fa-solid fa-ban"></i>`
                : `<i class="fa-solid fa-triangle-exclamation"></i>`;
            infoHTML = `<div class="act-info-bar">
                ${cfg.desc    ? `<div class="act-info-desc">${cfg.desc}</div>` : ""}
                ${cfg.warning ? `<div class="act-warn act-warn--${cfg.warningLevel ?? "warn"}">${warnIcon}${cfg.warning}</div>` : ""}
            </div>`;
        }

        const slotRows = Object.entries(slots)
            .sort(([,a],[,b]) => a.row.time_range.localeCompare(b.row.time_range))
            .map(([slotId, entry]) => buildSlotRowHTML(actSlug, slotId, day, entry, firstRow, aType))
            .join("");

        return `<div class="act-block">
            <div class="act-block__header">
                <div class="act-block__left">
                    <div class="act-block__icon" style="background:${cfg.color}"><i class="${cfg.icon}"></i></div>
                    <span class="act-block__name">${firstRow.activity_name}</span>
                </div>
            </div>
            ${infoHTML}${slotRows}
        </div>`;
    }

    async function renderPlannerSchedule() {
        const empty   = document.getElementById("plannerEmpty");
        const content = document.getElementById("plannerContent");
        if (!state.selectedMembers.size) { empty.style.display = "flex"; content.style.display = "none"; return; }
        empty.style.display = "none"; content.style.display = "block";
        [...state.selectedMembers]
            .filter((n) => !state.memberCache.has(n))
            .forEach((n) => fetchSchedule(n));
        buildActNameFilter();
        const grouped    = buildGrouped();
        const activeDays = DAY_KEYS.filter((d) => state.plannerDay === "all" || d === state.plannerDay);
        const html = activeDays
            .filter((d) => grouped[d])
            .map((day) =>
                `<div class="sched-day-block">
                    <div class="sched-day-header ${day}">${DAY_SHORT[day]}</div>
                    ${Object.entries(grouped[day]).map(([slug, slots]) => buildActBlockHTML(slug, slots, day)).join("")}
                </div>`
            ).join("");
        document.getElementById("scheduleBlocks").innerHTML =
            html || `<div class="text-center py-4" style="color:#b0a8c4;font-size:13px">ไม่มีรอบในวันที่เลือก</div>`;
    }

    // ── Round controls ────────────────────────────────────────────────────────
    function changeRounds(sid, actSlug, slotId, memberName, actNameEnc, day, timeEnc, aTypeEnc, ticketsRawStr, slotMembersEnc, delta) {
        const actName     = decodeURIComponent(actNameEnc);
        const time        = decodeURIComponent(timeEnc);
        const aType       = decodeURIComponent(aTypeEnc);
        const slotMembers = decodeURIComponent(slotMembersEnc).split(",").filter(Boolean);
        const ticketsReq  = ticketsRawStr === "null" || ticketsRawStr === null ? null : parseInt(String(ticketsRawStr)) || null;
        const current     = state.cart.get(sid)?.rounds ?? 0;
        const realActSlug = sid.split("__")[0];
        setRounds(
            { sid, member: memberName, actSlug: realActSlug, actName, actType: aType,
              day, dayLabel: DAY_SHORT[day] ?? day, time, members: slotMembers, ticketsReq },
            Math.max(0, current + delta)
        );
    }

    function setRoundsFromInput(input) {
        const val = Math.max(0, parseInt(input.value) || 0);
        input.value = String(val);
        const d = input.dataset, current = state.cart.get(d.sid)?.rounds ?? 0;
        changeRounds(d.sid, d.sid.split("__")[0], d.slotid, d.member, d.actname, d.day, d.time, d.atype, d.ticketsreq, d.slotmembers, val - current);
    }

    function updateSummaryBadge() {
        const badge = document.getElementById("summaryBadge");
        let total = 0;
        state.cart.forEach((c) => { total += c.rounds; });
        badge.textContent = String(total);
        badge.style.display = total > 0 ? "inline" : "none";
    }

    // ════════════════════════════════════════════════════════════════════════
    // HAPPENING NOW
    // ════════════════════════════════════════════════════════════════════════

    function renderHappeningNow() {
        const container = document.getElementById("nowContent");
        if (!container) return;

        const todayKey = detectTodayKey();
        const nowMin   = nowMinutes();

        if (!todayKey) {
            const nowBadge = document.getElementById("nowBadge");
            if (nowBadge) nowBadge.style.display = "none";
            container.innerHTML = `<div class="now-nothing-live">
                <div class="now-nothing-icon"><i class="fa-solid fa-calendar-xmark"></i></div>
                <div>ไม่มีกิจกรรมตามตารางในเวลานี้</div>
            </div>`;
            return;
        }

        const daySlots = FULL_SCHEDULE[todayKey] ?? [];

        const byTime = {};
        daySlots.forEach((s) => {
            byTime[s.time] ??= [];
            byTime[s.time].push(s);
        });
        const sortedTimes = Object.keys(byTime).sort();

        function renderActCards(time, opts = {}) {
            const slots = byTime[time];
            const byAct = {};
            slots.forEach((s) => {
                byAct[s.actSlug] ??= { actName: s.actName, members: [], actSlug: s.actSlug };
                s.members.forEach((m) => { if (!byAct[s.actSlug].members.includes(m)) byAct[s.actSlug].members.push(m); });
            });
            return Object.values(byAct).map((a) => {
                const cfg = findAct(a.actName, a.actSlug);
                const memberPills = a.members.map((m) => {
                    const img = memberImg(m);
                    const isSelected = state.selectedMembers.has(m);
                    const imgEl = img
                        ? `<img src="${img}" alt="${m}" style="width:20px;height:20px;border-radius:50%;object-fit:cover;object-position:top;flex-shrink:0${opts.past ? ";opacity:.5" : ""}" onerror="this.style.display='none'">`
                        : `<span style="width:20px;height:20px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:900;background:${cfg.color}22;color:${cfg.color};flex-shrink:0${opts.past ? ";opacity:.5" : ""}">${m[0]}</span>`;
                    return `<span class="now-member-pill ${isSelected ? "now-member-pill--sel" : ""}">${imgEl}${m}</span>`;
                }).join("");
                return `<div class="now-act-card${opts.past ? " now-act-card--past" : ""}">
                    <div class="now-act-card__header">
                        <span class="now-act-card__icon" style="background:${cfg.color}${opts.past ? ";opacity:.5" : ""}"><i class="${cfg.icon}"></i></span>
                        <span class="now-act-card__name"${opts.past ? ' style="opacity:.5"' : ""}>${a.actName}</span>
                    </div>
                    <div class="now-member-wrap">${memberPills}</div>
                </div>`;
            }).join("");
        }

        let currentTime = null;
        let nextTime    = null;

        for (const time of sortedTimes) {
            const { startMin, endMin } = parseTimeRange(time);
            if (nowMin >= startMin && nowMin < endMin) {
                currentTime = time;
            } else if (nowMin < startMin && nextTime === null) {
                nextTime = time;
            }
        }

        const nowBadge = document.getElementById("nowBadge");
        if (nowBadge) nowBadge.style.display = currentTime ? "inline" : "none";

        let html = "";

        if (currentTime) {
            html += `<div class="now-section-label now-section-label--live">Now Activities</div>
            <div class="now-time-block">
                <div class="now-time-label now-time-label--live">${currentTime}<span class="now-live-badge">LIVE</span></div>
                <div class="now-act-grid">${renderActCards(currentTime)}</div>
            </div>`;
        } else {
            html += `<div class="now-nothing-live">
                <div class="now-nothing-icon"><i class="fa-solid fa-clock"></i></div>
                <div>ยังไม่มีรอบที่เปิดอยู่ตอนนี้</div>
            </div>`;
        }

        if (nextTime) {
            html += `<div class="now-section-label now-section-label--next">Next Round</div>
            <div class="now-time-block now-time-block--next">
                <div class="now-time-label now-time-label--next">${nextTime}</div>
                <div class="now-act-grid">${renderActCards(nextTime)}</div>
            </div>`;
        }

        if (!currentTime && !nextTime) {
            html += `<div class="now-nothing-live" style="margin-top:16px">
                <div class="now-nothing-icon"><i class="fa-solid fa-flag-checkered"></i></div>
                <div>กิจกรรมวันนี้จบแล้ว</div>
            </div>`;
        }

        container.innerHTML = html;
    }

    setInterval(() => {
        if (document.getElementById("panel-happening")?.classList.contains("active")) {
            renderHappeningNow();
        }
    }, 60000);

    // ════════════════════════════════════════════════════════════════════════
    // EXPORT RECAP
    // ════════════════════════════════════════════════════════════════════════

    async function exportRecap() {
        const btn    = document.getElementById("exportRecapBtn");
        const canvas = document.getElementById("recapCanvas");
        if (btn) { btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> กำลังสร้าง...`; btn.disabled = true; }

        try {
            const [cssOutfit, cssNoto] = await Promise.all([
                fetch("https://fonts.googleapis.com/css2?family=Outfit:wght@700&display=swap").then(r => r.text()),
                fetch("https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@400;700&display=swap").then(r => r.text()),
            ]);

            function extractWoff2(css) {
                const match = css.match(/url\((https:\/\/fonts\.gstatic\.com\/[^)]+\.woff2)\)/);
                return match?.[1] ?? null;
            }

            const urlOutfit = extractWoff2(cssOutfit);
            const urlNoto   = extractWoff2(cssNoto);
            if (!urlOutfit || !urlNoto) throw new Error("Font URL not found");

            const [fontOutfit, fontNoto] = await Promise.all([
                new FontFace("Outfit", `url(${urlOutfit})`).load(),
                new FontFace("Noto Sans Thai", `url(${urlNoto})`).load(),
            ]);
            document.fonts.add(fontOutfit);
            document.fonts.add(fontNoto);
            await document.fonts.ready;

            const items = [...state.cart.values()].sort((a, b) => {
                const dCmp = (DAY_ORDER[a.day] ?? 0) - (DAY_ORDER[b.day] ?? 0);
                return dCmp || a.time.localeCompare(b.time);
            });
            items.forEach((c) => { if (!c.actSlug) c.actSlug = c.sid.split("__")[0]; });

            let totalTix = 0, totalPrice = 0;
            const memberSet = new Set();
            items.forEach((c) => {
                totalTix   += ticketsFor(c.actType, c.actName, c.actSlug, c.ticketsReq) * c.rounds;
                totalPrice += priceFor(c.actType, c.actName, c.actSlug, c.ticketsReq) * c.rounds;
                memberSet.add(c.member);
            });

            const PAD     = 20;
            const HDR_H   = 64;
            const STAT_H  = 72;
            const THEAD_H = 32;
            const ROW_H   = 46;
            const FOOT_H  = 56;
            const W       = 800;
            const H       = HDR_H + STAT_H + THEAD_H + (items.length * ROW_H) + FOOT_H;

            const dpr = window.devicePixelRatio || 1;
            canvas.width        = W * dpr;
            canvas.height       = H * dpr;
            canvas.style.width  = `${W}px`;
            canvas.style.height = `${H}px`;

            const ctx = canvas.getContext("2d");
            ctx.scale(dpr, dpr);

            const C = {
                bg:      "#ffffff",
                surface: "#f6f4fb",
                border:  "#ede9f7",
                primary: "#292848",
                text:    "#222233",
                muted:   "#999999",
                fri:     "#0ea5e9",
                sat:     "#8b5cf6",
                sun:     "#ef4444",
            };
            const DAY_COLOR = { fri: C.fri, sat: C.sat, sun: C.sun };

            function pill(color, x, y, w, h, r) {
                ctx.beginPath();
                ctx.roundRect(x, y, w, h, r);
                ctx.fillStyle = color;
                ctx.fill();
            }

            function line(x1, y1, x2, y2, color = C.border) {
                ctx.beginPath();
                ctx.moveTo(x1, y1);
                ctx.lineTo(x2, y2);
                ctx.strokeStyle = color;
                ctx.lineWidth = 0.5;
                ctx.stroke();
            }

            function txt(str, x, y, { size = 12, weight = "400", color = C.text, align = "left", font = "Outfit" } = {}) {
                ctx.font = `${weight} ${size}px "${font}"`;
                ctx.fillStyle = color;
                ctx.textAlign = align;
                ctx.textBaseline = "middle";
                ctx.fillText(str, x, y);
            }

            function hasThai(str) { return /[\u0E00-\u0E7F]/.test(str); }
            function smartFont(str) { return hasThai(str) ? "Noto Sans Thai" : "Outfit"; }

            let y = 0;
            ctx.fillStyle = C.primary;
            ctx.fillRect(0, y, W, HDR_H);
            txt("BNK48 & CGM48 Siam-Nippon Summer Fest 2026", PAD, y + 22, { size: 14, weight: "700", color: "#ffffff" });
            txt("My Activity Recap  ·  little-nemo-of-niya",  PAD, y + 44, { size: 11, color: "rgba(255,255,255,0.45)" });
            y += HDR_H;

            ctx.fillStyle = C.surface;
            ctx.fillRect(0, y, W, STAT_H);
            line(0, y + STAT_H, W, y + STAT_H);

            const stats = [
                { label: "ROUNDS",  value: String(items.length) },
                { label: "MEMBERS", value: String(memberSet.size) },
                { label: "TICKETS", value: String(totalTix), big: true },
                { label: "TOTAL",   value: `฿${totalPrice.toLocaleString()}` },
            ];
            const sw = W / stats.length;
            stats.forEach(({ label, value, big }, i) => {
                const sx = i * sw + sw / 2;
                txt(value, sx, y + 28, { size: big ? 26 : 22, weight: "700", color: C.primary, align: "center" });
                txt(label, sx, y + 54, { size: 10, color: C.muted, align: "center" });
                if (i < stats.length - 1) line(i * sw + sw, y + 12, i * sw + sw, y + STAT_H - 12);
            });
            y += STAT_H;

            ctx.fillStyle = C.surface;
            ctx.fillRect(0, y, W, THEAD_H);
            line(0, y + THEAD_H, W, y + THEAD_H);

            const cols = [
                { label: "MEMBER",   x: PAD },
                { label: "ACTIVITY", x: PAD + 150 },
                { label: "DAY",      x: PAD + 345 },
                { label: "TIME",     x: PAD + 420 },
                { label: "ROUND",    x: PAD + 530 },
                { label: "PRICE",    x: W - PAD },
            ];
            cols.forEach(({ label, x }) => {
                const align = label === "PRICE" ? "right" : "left";
                txt(label, x, y + THEAD_H / 2, { size: 10, weight: "700", color: C.muted, align });
            });
            y += THEAD_H;

            items.forEach((c, idx) => {
                const price = priceFor(c.actType, c.actName, c.actSlug, c.ticketsReq) * c.rounds;
                const cfg   = findAct(c.actName, c.actSlug);
                const ry    = y + idx * ROW_H;
                const mid   = ry + ROW_H / 2;

                ctx.fillStyle = C.surface;
                ctx.fillRect(0, ry, W, ROW_H);
                line(0, ry + ROW_H, W, ry + ROW_H);

                const isBNK = memberMeta(c.member).brand === "BNK48";
                ctx.beginPath();
                ctx.arc(cols[0].x + 13, mid, 13, 0, Math.PI * 2);
                ctx.fillStyle = isBNK ? "#e8e4f8" : "#fce8f0";
                ctx.fill();
                txt(c.member[0], cols[0].x + 13, mid, { size: 11, weight: "700", color: isBNK ? C.primary : "#c0397a", align: "center" });
                txt(c.member, cols[0].x + 30, mid, { size: 12, weight: "700" });

                ctx.beginPath();
                ctx.arc(cols[1].x + 5, mid, 4, 0, Math.PI * 2);
                ctx.fillStyle = cfg.color;
                ctx.fill();
                txt(c.actName, cols[1].x + 14, mid, { size: 12, weight: "700", font: smartFont(c.actName) });

                const dc = DAY_COLOR[c.day] ?? "#9b90b8";
                pill(dc + "22", cols[2].x, mid - 10, 62, 20, 10);
                txt(c.dayLabel ?? c.day.toUpperCase(), cols[2].x + 31, mid, { size: 10, weight: "700", color: dc, align: "center" });

                txt(c.time, cols[3].x, mid, { size: 12, weight: "700" });

                pill(C.primary, cols[4].x, mid - 12, 24, 24, 12);
                txt(String(c.rounds), cols[4].x + 12, mid, { size: 11, weight: "700", color: "#fff", align: "center" });

                txt(price > 0 ? `฿${price.toLocaleString()}` : "—", W - PAD, mid, { size: 12, weight: "700", align: "right" });
            });

            y += items.length * ROW_H;

            ctx.fillStyle = C.primary;
            ctx.fillRect(0, y, W, FOOT_H);
            txt("GRAND TOTAL",                                    PAD,     y + 20, { size: 10, color: "rgba(255,255,255,0.45)" });
            txt(`${totalTix} tickets · ${items.length} rounds`,  PAD,     y + 38, { size: 11, color: "rgba(255,255,255,0.35)" });
            txt(`฿${totalPrice.toLocaleString()}`,               W - PAD, y + FOOT_H / 2, { size: 22, weight: "700", color: "#fff", align: "right" });

            const link = document.createElement("a");
            link.download = `summerfest-recap-${Date.now()}.png`;
            link.href = canvas.toDataURL("image/png");
            link.click();

            showToast("บันทึก Recap แล้ว!");
        } catch (err) {
            console.error(err);
            showToast("เกิดข้อผิดพลาด กรุณาลองใหม่");
        } finally {
            if (btn) { btn.innerHTML = `<i class="fa-solid fa-image"></i> Export Recap`; btn.disabled = false; }
        }
    }

    function roundRect(ctx, x, y, w, h, r) {
        ctx.beginPath();
        ctx.moveTo(x + r, y);
        ctx.lineTo(x + w - r, y);
        ctx.quadraticCurveTo(x + w, y, x + w, y + r);
        ctx.lineTo(x + w, y + h - r);
        ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
        ctx.lineTo(x + r, y + h);
        ctx.quadraticCurveTo(x, y + h, x, y + h - r);
        ctx.lineTo(x, y + r);
        ctx.quadraticCurveTo(x, y, x + r, y);
        ctx.closePath();
        ctx.fill();
    }

    // ════════════════════════════════════════════════════════════════════════
    // SUMMARY
    // ════════════════════════════════════════════════════════════════════════

    const SORT_OPTIONS = [
        { key: "day",      label: "Time" },
        { key: "member",   label: "Member" },
        { key: "activity", label: "Activity" },
        { key: "round",    label: "Round" },
        { key: "price",    label: "Price" },
    ];

    function buildSortBar() {
        const menu = document.getElementById("sortMenu");
        if (!menu) return;
        menu.innerHTML = SORT_OPTIONS.map((o) => {
            const active = state.summarySort === o.key;
            const arrow  = active ? (state.summarySortDir === "asc" ? "↑" : "↓") : "";
            return `<button class="sort-menu-item ${active ? "active" : ""}" onclick="APP.setSort('${o.key}')"><span>${o.label}</span><span class="sort-menu-item__arrow">${arrow}</span></button>`;
        }).join("");
        const lbl = document.getElementById("sortActiveLabel");
        if (lbl) lbl.textContent = `${SORT_OPTIONS.find((o) => o.key === state.summarySort)?.label} ${state.summarySortDir === "asc" ? "↑" : "↓"}`;
    }

    function toggleSortMenu() {
        const open = document.getElementById("sortMenu").classList.toggle("open");
        document.getElementById("sortToggleBtn").classList.toggle("open", open);
    }

    document.addEventListener("click", (e) => {
        const wrap = document.getElementById("sortDropdownWrap");
        if (wrap && !wrap.contains(e.target)) {
            document.getElementById("sortMenu")?.classList.remove("open");
            document.getElementById("sortToggleBtn")?.classList.remove("open");
        }
    });

    function setSort(key) {
        state.summarySortDir = state.summarySort === key
            ? (state.summarySortDir === "asc" ? "desc" : "asc")
            : "asc";
        state.summarySort = key;
        document.getElementById("sortMenu")?.classList.remove("open");
        document.getElementById("sortToggleBtn")?.classList.remove("open");
        buildSortBar();
        renderSummaryTable();
        saveToStorage();
    }

    function renderSummaryTab() {
        const empty   = document.getElementById("summaryEmpty");
        const content = document.getElementById("summaryContent");
        if (!state.cart.size) { empty.style.display = "flex"; content.style.display = "none"; return; }
        empty.style.display = "none"; content.style.display = "block";
        let totalRounds = 0, totalTix = 0, totalPrice = 0;
        const memberSet = new Set();
        state.cart.forEach((c) => {
            if (!c.actSlug) c.actSlug = c.sid.split("__")[0];
            totalRounds += c.rounds;
            totalTix    += ticketsFor(c.actType, c.actName, c.actSlug, c.ticketsReq) * c.rounds;
            totalPrice  += priceFor(c.actType, c.actName, c.actSlug, c.ticketsReq) * c.rounds;
            memberSet.add(c.member);
        });
        document.getElementById("statGrid").innerHTML = [
            { label: "Rounds",  value: totalRounds,                       unit: "Round" },
            { label: "Members", value: memberSet.size,                    unit: "คน" },
            { label: "Tickets", value: totalTix,                          unit: "ใบ" },
            { label: "Total",   value: `฿${totalPrice.toLocaleString()}`, unit: "Bath" },
        ].map((s) => `<div class="stat-card"><div class="stat-card__label">${s.label}</div><div class="stat-card__value">${s.value}</div><div class="stat-card__unit">${s.unit}</div></div>`).join("");
        buildSortBar();
        renderSummaryTable();
        renderSummaryFooter();
    }

    function removeFromCart(sid) {
        state.cart.delete(sid);
        updateSummaryBadge();
        saveToStorage();
        renderSummaryTab();
        renderPlannerSchedule();
    }

    function renderSummaryTable() {
        const filtered = [...state.cart.values()]
            .filter((c) => state.summaryDay === "all" || c.day === state.summaryDay)
            .sort((a, b) => {
                let cmp = 0;
                switch (state.summarySort) {
                    case "day":      cmp = (DAY_ORDER[a.day] ?? 0) - (DAY_ORDER[b.day] ?? 0); if (!cmp) cmp = a.time.localeCompare(b.time); break;
                    case "member":   cmp = a.member.localeCompare(b.member, "th");   break;
                    case "activity": cmp = a.actName.localeCompare(b.actName, "th"); break;
                    case "round":    cmp = a.rounds - b.rounds;                      break;
                    case "price":    cmp = priceFor(a.actType, a.actName, a.actSlug, a.ticketsReq) * a.rounds
                                        - priceFor(b.actType, b.actName, b.actSlug, b.ticketsReq) * b.rounds; break;
                }
                return state.summarySortDir === "asc" ? cmp : -cmp;
            });
        const tbody = document.getElementById("summaryTbody");
        if (!filtered.length) {
            tbody.innerHTML = `<tr><td colspan="6" class="text-center py-4" style="color:#b0a8c4;font-size:13px">ไม่มี Round ในวันนี้</td></tr>`;
            return;
        }
        tbody.innerHTML = filtered.map((c) => {
            if (!c.actSlug) c.actSlug = c.sid.split("__")[0];
            const isBNK    = memberMeta(c.member).brand === "BNK48";
            const img      = memberImg(c.member);
            const avHTML   = img
                ? `<img src="${img}" alt="${c.member}" class="tbl-av" loading="lazy" onerror="this.outerHTML='<div class=\\'tbl-av-fallback ${isBNK ? "av--bnk" : "av--cgm"}\\'>${c.member[0]}</div>'">`
                : `<div class="tbl-av-fallback ${isBNK ? "av--bnk" : "av--cgm"}">${c.member[0]}</div>`;
            const tix      = ticketsFor(c.actType, c.actName, c.actSlug, c.ticketsReq) * c.rounds;
            const price    = priceFor(c.actType, c.actName, c.actSlug, c.ticketsReq) * c.rounds;
            const priceStr = price > 0 ? `฿${price.toLocaleString()}` : "—";
            const cfg      = findAct(c.actName, c.actSlug);
            return `<tr>
                <td><div class="tbl-member-cell">${avHTML}<span class="tbl-name">${c.member}</span></div></td>
                <td><div class="d-flex align-items-center gap-2" style="font-size:12px"><span style="width:20px;height:20px;border-radius:6px;background:${cfg.color};display:inline-flex;align-items:center;justify-content:center;flex-shrink:0"><i class="${cfg.icon}" style="font-size:9px;color:#fff"></i></span>${c.actName}</div></td>
                <td style="text-align:center"><span class="day-chip ${c.day}">${c.dayLabel}</span></td>
                <td style="font-variant-numeric:tabular-nums;font-size:12px;text-align:center">${c.time}</td>
                <td class="text-center"><span class="tbl-ticket-badge">${c.rounds}</span>${tix > 0 ? `<div style="font-size:10px;color:#b0a8c4;margin-top:2px">${tix} Ticket</div>` : ""}</td>
                <td class="text-end"><div class="d-flex align-items-center justify-content-end gap-2"><span style="font-weight:700;color:var(--c-primary)">${priceStr}</span><button class="tbl-del-btn" onclick="APP.removeFromCart('${c.sid}')" title="Remove"><i class="fa-solid fa-xmark"></i></button></div></td>
            </tr>`;
        }).join("");
    }

    function renderSummaryFooter() {
        const memberTotals = new Map();
        state.cart.forEach((c) => {
            if (!c.actSlug) c.actSlug = c.sid.split("__")[0];
            const t = memberTotals.get(c.member) ?? { rounds: 0, tix: 0, price: 0 };
            memberTotals.set(c.member, {
                rounds: t.rounds + c.rounds,
                tix:    t.tix   + ticketsFor(c.actType, c.actName, c.actSlug, c.ticketsReq) * c.rounds,
                price:  t.price + priceFor(c.actType, c.actName, c.actSlug, c.ticketsReq)   * c.rounds,
            });
        });
        const rows = [...memberTotals.entries()]
            .map(([name, t]) => `<div class="sfooter-member-row"><span class="sfooter-name">${name}</span><span class="sfooter-slots">${t.rounds} Round · ${t.tix} Ticket</span><span class="sfooter-price">฿${t.price.toLocaleString()}</span></div>`)
            .join("");
        let grand = 0, grandTix = 0, grandRounds = 0;
        memberTotals.forEach((t) => { grand += t.price; grandTix += t.tix; grandRounds += t.rounds; });
        document.getElementById("summaryFooter").innerHTML =
            `<div>${rows}</div><div class="sfooter-grand"><div><div class="sfooter-grand-label">Grand Total</div><div style="font-size:12px;color:#b0a8c4;margin-top:2px">${grandTix} Ticket · ${grandRounds} Round</div></div><div class="d-flex align-items-baseline gap-1"><div class="sfooter-grand-val">${grand.toLocaleString()}</div><div class="sfooter-grand-unit">บาท</div></div></div>`;
    }

    document.getElementById("summaryDayTabs")?.addEventListener("click", (e) => {
        const btn = e.target.closest(".day-tab");
        if (!btn) return;
        document.querySelectorAll(".day-tab").forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        state.summaryDay = btn.dataset.day;
        renderSummaryTable();
        saveToStorage();
    });

    // ── Reset ─────────────────────────────────────────────────────────────────
    function resetAll() {
        if (!confirm("Reset ทั้งหมด?")) return;
        state.cart.clear();
        state.selectedMembers.forEach((name) => {
            const btn = document.querySelector(`.member-card__select-btn[data-name="${CSS.escape(name)}"]`);
            if (btn) { btn.classList.remove("active"); btn.innerHTML = ICON_ADD + " Add to Planner"; }
        });
        state.selectedMembers.clear();
        state.plannerActNames.clear();
        localStorage.removeItem(STORAGE_KEY);
        renderSelectedMembersStrip();
        renderPlannerSchedule();
        updateSummaryBadge();
        renderSummaryTab();
        showToast("Reset แล้ว");
    }

    // ── Load from storage ─────────────────────────────────────────────────────
    async function loadFromStorage() {
        try {
            const raw = localStorage.getItem(STORAGE_KEY);
            if (!raw) return;
            const p = JSON.parse(raw);
            STATE_KEYS.forEach((k) => { if (p[k] != null) state[k] = p[k]; });
            const firstSlug = (p.plannerActNames ?? [])[0];
            if (firstSlug) state.plannerActNames.add(firstSlug);
            await Promise.all(
                (p.selectedMembers ?? []).map(async (name) => {
                    state.selectedMembers.add(name);
                    const btn = document.querySelector(`.member-card__select-btn[data-name="${CSS.escape(name)}"]`);
                    if (btn) { btn.classList.add("active"); btn.innerHTML = ICON_CHECK + " Added"; }
                    fetchSchedule(name);
                })
            );
            (p.cart ?? []).forEach(({ sid, item }) => {
                if (!item.actSlug) item.actSlug = sid.split("__")[0];
                state.cart.set(sid, item);
            });

            document.querySelectorAll("#nowDateRow [data-nowday]").forEach((b) =>
                b.classList.toggle("active", b.dataset.nowday === state.nowDay)
            );

            applyMemberCardFilter();
            document.querySelectorAll("#mBrandGroup .ftab").forEach((b) => b.classList.toggle("active", b.dataset.mv === state.mFilterBrand));
            buildMemberPageChips();
            document.querySelectorAll("#dayFilterRow .day-ftab").forEach((b) => b.classList.toggle("active", b.dataset.day === state.plannerDay));
            document.querySelectorAll(".day-tab").forEach((b) => b.classList.toggle("active", b.dataset.day === state.summaryDay));
            renderSelectedMembersStrip();
            renderPlannerSchedule();
            updateSummaryBadge();
        } catch {}
    }

    // ── Public API ────────────────────────────────────────────────────────────
    const APP = {
        switchTab,
        toggleMember,
        removeMember: removeMemberFromPlanner,
        changeRounds,
        setRoundsFromInput,
        resetAll,
        removeFromCart,
        setSort,
        toggleSortMenu,
        exportRecap,
    };
    window.APP = APP;
    window.toggleFromMembersTab = (btn) => APP.toggleMember(btn);

    loadFromStorage();
</script>