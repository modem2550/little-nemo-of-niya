---
// ./components/SocialLinks.astro
import socialData from "../data/social.json";

// ใช้ Astro component แทน renderSocialLinks() ใน global.js
// เพื่อหลีกเลี่ยง duplication และทำงานที่ build-time แทน runtime
---

<div id="social-links-container">
  <div class="row g-3">
    {socialData.map(({ platform, url, username, iconId }) => {
      const slug = platform.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-').trim();
      return (
        <div class="col-6 col-md-4">
          <a href={url} target="_blank" rel="noopener noreferrer" class={`social-box -${slug} social-link h-100`} title={platform} aria-label={platform}>
            <svg viewBox="0 0 512 512" class={`svg-inline--fa fa-${slug}`} role="img" aria-hidden="true">
              <use href={`#${iconId}`} />
            </svg>
            <div>
              <div class="fw-bold social-margin h6">
                {platform}
                <svg class="icon arrow-svg ms-1" width="24" height="24" aria-hidden="true"><use href="#icon-arrow-right"></use></svg>
              </div>
              <div class="fw-bold social-margin h4">{username}</div>
            </div>
          </a>
        </div>
      );
    })}
  </div>
</div>