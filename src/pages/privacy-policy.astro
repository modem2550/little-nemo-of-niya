---
// src/pages/privacy-policy.astro
import MainLayout from "../layouts/MainLayout.astro";

export interface Props {
title?: string;
}

const { title = "นโยบายความเป็นส่วนตัว (Privacy Policy)" } = Astro.props;
---

<MainLayout title={title}>
    <div class="policy-page">
        <div class="policy-container container">
            <h1 class="policy-title">นโยบายความเป็นส่วนตัว (Privacy Policy)</h1>
            <p class="last-updated">อัปเดตล่าสุด: 7 เมษายน 2569</p>

            <section class="policy-section">
                <h2 class="wp-block-heading">ข้อมูลที่เราเก็บรวบรวม</h2>
                <p>
                    Niya BNK48 – Fan Website (“เรา”)
                    ให้ความสำคัญกับความเป็นส่วนตัวของผู้ใช้งาน เว็บไซต์ของเรา
                    <strong>ไม่มีระบบสมัครสมาชิกและไม่มีการเก็บข้อมูลส่วนบุคคลโดยตรง</strong> เช่น ชื่อ-นามสกุล, อีเมล,
                    ที่อยู่ หรือหมายเลขโทรศัพท์ อย่างไรก็ตาม
                    การใช้งานเว็บไซต์ของคุณอาจก่อให้เกิดการเก็บข้อมูลบางประเภทโดยอัตโนมัติผ่านเทคโนโลยีมาตรฐาน
                    ดังนี้:
                </p>
                <ul class="policy-list">
                    <li>
                        <strong>LocalStorage
                            (พื้นที่จัดเก็บภายในเบราว์เซอร์ของคุณ):</strong> เว็บไซต์ใช้ LocalStorage เพื่อบันทึกผลเกม
                        (game results),
                        ข้อมูลเกมจัดอันดับ (ranking game), ข้อมูลแผนกิจกรรม (event
                        planner) และการตั้งค่าผู้ใช้ (user preferences) ข้อมูลเหล่านี้จะถูกเก็บเฉพาะในอุปกรณ์ของคุณ
                        และไม่สามารถเข้าถึงได้โดยเราโดยตรง
                    </li>
                    <li>
                        <strong>คุกกี้ (Cookies) และเทคโนโลยีการวิเคราะห์:</strong> เราใช้ Google Analytics, Vercel
                        Analytics รวมถึงบริการของ
                        Cloudflare เพื่อทำความเข้าใจพฤติกรรมผู้ใช้และปรับปรุงประสิทธิภาพเว็บไซต์
                        ซึ่งอาจมีการบันทึกที่อยู่ IP แบบไม่ระบุตัวตน, ชนิดของเบราว์เซอร์,
                        ระบบปฏิบัติการ, เวลาเข้าใช้งาน และหน้าเว็บที่เข้าชม
                    </li>
                    <li>
                        <strong>เนื้อหาจากบุคคลที่สาม (Third-party Embeds):</strong> วิดีโอ YouTube,
                        พลังงานโซเชียลมีเดีย (Twitter/X, Instagram)
                        และฟอนต์จาก Google Fonts อาจมีการเก็บข้อมูลของตนเองเพิ่มเติม
                        (ดูรายละเอียดในนโยบายคุกกี้)
                    </li>
                </ul>
                <p>
                    เราไม่ได้เก็บข้อมูลที่ละเอียดอ่อนใด ๆ
                    และไม่มีการเก็บข้อมูลบัตรเครดิตหรือข้อมูลการชำระเงิน
                    เนื่องจากเว็บไซต์ไม่มีระบบซื้อขายสินค้าหรือบริการ
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">วัตถุประสงค์ของการใช้ข้อมูล</h2>
                <p>
                    ข้อมูลที่เรารวบรวม (ไม่ว่าจะผ่าน LocalStorage หรือ Analytics
                    ) ถูกนำไปใช้เพื่อวัตถุประสงค์ดังต่อไปนี้:
                </p>
                <ul class="policy-list">
                    <li>
                        เพื่อให้ฟีเจอร์ต่าง ๆ ทำงานได้ถูกต้อง เช่น
                        การบันทึกผลเกม, การแสดงแผนกิจกรรมตามที่ผู้ใช้กำหนด,
                        การจดจำธีมหรือการตั้งค่าส่วนตัว
                    </li>
                    <li>
                        เพื่อวิเคราะห์ปริมาณการเข้าชม พฤติกรรมโดยรวมของผู้ใช้
                        และประสิทธิภาพของหน้าเว็บ (เช่น หน้าใดได้รับความนิยม,
                        อัตราการออกจากหน้า) โดยไม่สามารถระบุตัวบุคคลได้
                    </li>
                    <li>
                        เพื่อปรับปรุงประสบการณ์การใช้งาน แก้ไขข้อผิดพลาด
                        และเพิ่มความปลอดภัยให้กับเว็บไซต์ (ผ่าน Cloudflare CDN
                        และบริการป้องกัน DDoS)
                    </li>
                    <li>
                        เพื่อพัฒนาเกมจัดอันดับและเครื่องมือแฟนคลับอื่น ๆ
                        โดยใช้สถิติรวมที่ไม่ระบุตัวตน
                    </li>
                </ul>
            </section>

            <section class="policy-section">
                <h2>Local Storage และสิทธิ์ในการควบคุม</h2>
                <p>
                    ข้อมูล LocalStorage
                    ถูกเก็บไว้เฉพาะในเบราว์เซอร์ของคุณเท่านั้น
                    คุณสามารถลบหรือจัดการข้อมูลนี้ได้ตลอดเวลาผ่านเครื่องมือนักพัฒนาซอฟต์แวร์
                    (DevTools) หรือการตั้งค่าความเป็นส่วนตัวของเบราว์เซอร์
                    (ตัวเลือก "ล้างข้อมูลการจัดเก็บไซต์") หากคุณลบข้อมูล
                    LocalStorage ฟังก์ชันบางอย่างของเว็บไซต์ (เช่น
                    ผลการเล่นเกมที่บันทึกไว้, แผนกิจกรรมที่สร้าง)
                    อาจถูกลบและไม่สามารถกู้คืนได้
                </p>
                <p>
                    เราไม่สามารถเข้าถึงหรืออ่านข้อมูล LocalStorage
                    ของคุณจากเซิร์ฟเวอร์ได้
                    ข้อมูลนี้จะไม่ถูกส่งให้เราหรือบุคคลที่สามโดยอัตโนมัติ
                    เว้นแต่จะเป็นส่วนหนึ่งของการโต้ตอบกับฟีเจอร์ที่ต้องส่งข้อมูล
                    (เช่น การส่งคะแนนเกมเข้าร่วมอันดับรวม
                    ซึ่งผู้ใช้เป็นผู้เลือกดำเนินการ)
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">คุกกี้ (Cookies)</h2>
                <p>
                    เว็บไซต์ของเราใช้คุกกี้เพื่อการวิเคราะห์และรองรับเนื้อหาจากบุคคลที่สาม
                    โดยคุกกี้ที่ใช้มีรายละเอียดแยกต่างหากใน <a href="/cookies-policy">นโยบายการใช้คุกกี้</a> ของเรา
                    โดยสรุป:
                </p>
                <ul class="policy-list">
                    <li>
                        <strong>คุกกี้จาก Google Analytics และ Vercel Analytics:</strong>
                        ใช้เก็บสถิติการเข้าชมแบบไม่ระบุตัวตน
                    </li>
                    <li>
                        <strong>คุกกี้จาก YouTube, Twitter, Instagram:</strong>
                        อาจถูกตั้งค่าเมื่อคุณดูวิดีโอหรือโต้ตอบกับโพสต์ที่ฝังไว้บนเว็บไซต์ของเรา
                    </li>
                    <li>
                        <strong>คุกกี้จาก Cloudflare:</strong> เพื่อความปลอดภัยและประสิทธิภาพของเครือข่าย
                    </li>
                </ul>
                <p>
                    คุณสามารถปิดการใช้งานคุกกี้ผ่านการตั้งค่าเบราว์เซอร์ของคุณได้
                    อย่างไรก็ตาม การปิดคุกกี้อาจส่งผลให้ฟีเจอร์บางอย่าง (เช่น
                    การฝังวิดีโอ) ทำงานไม่สมบูรณ์
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">
                    เนื้อหาจากบุคคลที่สาม (Third-party Content)
                </h2>
                <h3 class="wp-block-heading">
                    ผู้ให้บริการโครงสร้างพื้นฐานและบุคคลที่สาม (Third-party
                    Infrastructure Providers)
                </h3>
                <p>
                    เราใช้บริการจากพันธมิตรทางเทคโนโลยีเพื่อโฮสต์และรักษาความปลอดภัยเว็บไซต์
                    ซึ่งอาจมีการประมวลผลข้อมูลของผู้ใช้ในนามของเรา
                    โดยผู้ให้บริการเหล่านี้มีนโยบายความเป็นส่วนตัวของตนเอง:
                </p>
                <ul class="policy-list">
                    <li>
                        <strong>Vercel (โฮสติ้ง):</strong> เก็บ log ของเซิร์ฟเวอร์
                        เช่น ที่อยู่ IP, User Agent, และเวลาที่ร้องขอ ดูนโยบายได้ที่
                        <a href="https://vercel.com/legal/privacy-policy" target="_blank"
                            rel="noopener noreferrer">Vercel Privacy Policy</a>
                    </li>
                    <li>
                        <strong>Cloudflare (CDN & Security):</strong> อาจเก็บที่อยู่
                        IP และข้อมูลการเชื่อมต่อเพื่อป้องกันการโจมตี ดูนโยบายได้ที่
                        <a href="https://www.cloudflare.com/privacypolicy/" target="_blank"
                            rel="noopener noreferrer">Cloudflare Privacy Policy</a>
                    </li>
                    <li>
                        <strong>Supabase (Backend Database):</strong>
                        จัดเก็บข้อมูลที่ไม่ระบุตัวตนสำหรับฟีเจอร์ของเว็บไซต์
                        ดูนโยบายได้ที่ <a href="https://supabase.com/privacy" target="_blank"
                            rel="noopener noreferrer">Supabase Privacy Policy</a>
                    </li>
                    <li>
                        <strong>Google (Analytics, Fonts, YouTube):</strong> ดูนโยบายรวมได้ที่
                        <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Google
                            Privacy Policy</a>
                    </li>
                    <li>
                        <strong>Twitter/X และ Instagram (Meta):</strong>
                        มีนโยบายความเป็นส่วนตัวของตนเองสำหรับการฝังเนื้อหา
                    </li>
                </ul>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">สิทธิ์ของผู้ใช้ (User Rights)</h2>
                <p>
                    เนื่องจากเราไม่ได้เก็บข้อมูลส่วนบุคคลที่ระบุตัวตนได้โดยตรง
                    (ไม่มีบัญชีผู้ใช้, ไม่มีอีเมล ฯลฯ) สิทธิ์ในการเข้าถึง แก้ไข
                    หรือลบข้อมูลส่วนบุคคลจึงอาจไม่สามารถดำเนินการได้ในลักษณะเดียวกับบริการที่มีระบบสมาชิก
                    อย่างไรก็ตาม คุณมีสิทธิดังต่อไปนี้:
                </p>
                <ul class="policy-list">
                    <li>
                        <strong>สิทธิ์ในการล้าง LocalStorage:</strong>
                        คุณสามารถลบข้อมูลทั้งหมดที่เว็บไซต์จัดเก็บไว้ในเบราว์เซอร์ได้ตามวิธีที่อธิบายในข้อ
                        3
                    </li>
                    <li>
                        <strong>สิทธิ์ในการปิดคุกกี้:</strong> ตั้งค่าเบราว์เซอร์ของคุณเพื่อปฏิเสธคุกกี้ทั้งหมด
                        หรือลบคุกกี้ที่มีอยู่
                    </li>
                    <li>
                        <strong>สิทธิ์ในการปฏิเสธการติดตามของ Google Analytics:</strong> ติดตั้ง <a
                            href="https://tools.google.com/dlpage/gaoptout" target="_blank"
                            rel="noopener noreferrer">Google Analytics Opt-out Browser Add-on</a>
                    </li>
                    <li>
                        <strong>สิทธิ์ในการขอข้อมูลที่เราอาจเก็บไว้ใน Supabase:</strong>
                        หากคุณเชื่อว่ามีข้อมูลที่ระบุตัวตนคุณโดยไม่ตั้งใจ โปรดติดต่อเราตามช่องทางด้านล่าง
                        เราจะตรวจสอบและลบให้โดยเร็ว
                    </li>
                </ul>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">
                    ระยะเวลาในการเก็บรักษาข้อมูล (Data Retention)
                </h2>
                <p>
                    ข้อมูล LocalStorage
                    จะถูกเก็บไว้ในเบราว์เซอร์ของคุณจนกว่าคุณจะลบหรือหมดอายุการใช้งานตามนโยบายของเบราว์เซอร์
                    ข้อมูลใน Google Analytics และ Vercel Analytics
                    จะถูกเก็บรักษาตามนโยบายของแต่ละบริการ (โดยทั่วไปสูงสุด 14–26
                    เดือน) ข้อมูลใน Supabase
                    สำหรับสถิติรวมจะถูกเก็บไว้อย่างไม่มีกำหนดตราบใดที่ยังจำเป็นสำหรับการให้บริการฟีเจอร์ของเว็บไซต์
                    หากไม่จำเป็นอีกต่อไป
                    เราจะทำการลบหรือทำให้ไม่สามารถระบุตัวตนได้
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">
                    การเปลี่ยนแปลงนโยบายความเป็นส่วนตัว
                </h2>
                <p>
                    เราอาจอัปเดตนโยบายนี้เป็นครั้งคราวเพื่อให้สอดคล้องกับข้อกำหนดทางกฎหมายหรือการเปลี่ยนแปลงของฟีเจอร์ในเว็บไซต์
                    โดยวันที่มีผลบังคับใช้ (อัปเดตล่าสุด)
                    จะแสดงไว้ด้านบนของหน้านี้
                    เราขอแนะนำให้คุณตรวจสอบหน้านี้เป็นระยะ ๆ
                    เพื่อรับทราบการเปลี่ยนแปลง
                    การใช้งานเว็บไซต์ต่อไปหลังจากมีการแก้ไขนโยบายถือว่าคุณยอมรับการแก้ไขดังกล่าว
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">ข้อมูลติดต่อ</h2>
                <p>
                    หากคุณมีข้อสงสัยหรือข้อกังวลเกี่ยวกับนโยบายความเป็นส่วนตัวนี้
                    หรือต้องการใช้สิทธิ์ใด ๆ ที่เกี่ยวข้องกับข้อมูลของคุณ
                    โปรดติดต่อเราที่:
                </p>
                <address>
                    อีเมล: <a href="mailto:teamniya.thfc1402@gmail.com">teamniya.thfc1402@gmail.com</a>
                    <br />
                    เว็บไซต์: <a
                        href="https://little-nemo-of-niya.vercel.app">https://little-nemo-of-niya.vercel.app</a>
                    <br />
                    X: <a href="https://x.com/niyabnk48_thfc">@niyabnk48_thfc</a>
                </address>
            </section>
        </div>
    </div>
</MainLayout>