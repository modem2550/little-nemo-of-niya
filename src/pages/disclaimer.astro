---
// src/pages/disclaimer.astro
import MainLayout from "@/app/layouts/MainLayout.astro";

export interface Props {
    title?: string;
}

const { title = "คำชี้แจงสำหรับแฟนไซต์ (Fan Site Disclaimer)" } = Astro.props;
---

<MainLayout title={title}>
    <div class="policy-page">
        <div class="policy-container container">
            <h1 class="policy-title">คำชี้แจงสำหรับแฟนไซต์ (Disclaimer)</h1>
            <p class="last-updated">อัปเดตล่าสุด: 7 เมษายน 2569</p>

            <section class="policy-section">
                <h2 class="wp-block-heading">สถานะของเว็บไซต์</h2>
                <p>
                    <strong>Niya BNK48 – Fan Website</strong> (URL: <a
                        href="https://little-nemo-of-niya.vercel.app"
                        >https://little-nemo-of-niya.vercel.app</a
                    >) เป็นเว็บไซต์ที่สร้างขึ้นโดยกลุ่มแฟนคลับ (Fan Project)
                    เพื่อสนับสนุนและให้ข้อมูลเกี่ยวกับศิลปินไอดอลวง BNK48
                    โดยเฉพาะสมาชิก “นีญ่า” (Niya) เว็บไซต์นี้ <strong
                        >ไม่มีความเกี่ยวข้อง ไม่ได้เป็นตัวแทน
                        และไม่ได้รับการรับรองอย่างเป็นทางการจาก BNK48, CGM48
                        หรือ iAM (บริษัทผู้ดูแล BNK48 และ CGM48),
                        ผู้สนับสนุนอย่างเป็นทางการ หรือหน่วยงานใด ๆ
                        ที่เกี่ยวข้องกับวง BNK48 และ CGM48</strong
                    >
                </p>
                <p>
                    ข้อมูล ความคิดเห็น
                    และเนื้อหาทั้งหมดบนเว็บไซต์นี้เป็นมุมมองของแฟนคลับที่จัดทำขึ้น
                    โดยมีเจตนาเพื่อสนับสนุนและเผยแพร่ผลงานของศิลปินในทางสร้างสรรค์เท่านั้น
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">ลิขสิทธิ์และเครื่องหมายการค้า</h2>
                <p>
                    ชื่อ “BNK48”, “Niya”, โลโก้ของวง, รูปภาพอย่างเป็นทางการ,
                    เพลง, มิวสิควิดีโอ, และทรัพย์สินทางปัญญาอื่น ๆ ที่เกี่ยวข้อง
                    เป็นลิขสิทธิ์และเครื่องหมายการค้าของ BNK48, iAM,
                    และพันธมิตรตามที่กฎหมายกำหนด
                    การใช้ชื่อและภาพดังกล่าวในเว็บไซต์นี้มีขึ้นเพื่อวัตถุประสงค์ในการเป็นแฟนไซต์
                    (fan site) โดยไม่แสวงหาผลกำไร
                    และอยู่ภายใต้หลักการใช้งานโดยชอบ (fair use)
                    ตามพระราชบัญญัติลิขสิทธิ์ พ.ศ. 2537 (และฉบับแก้ไข)
                    เพื่อการวิจารณ์, ให้ความรู้,
                    หรือการนำเสนอข้อมูลที่เป็นประโยชน์ต่อชุมชนแฟนคลับ
                </p>
                <p>
                    หากคุณเป็นเจ้าของลิขสิทธิ์หรือตัวแทนโดยชอบด้วยกฎหมาย
                    และเชื่อว่าเนื้อหาในเว็บไซต์นี้ละเมิดสิทธิ์ของคุณ
                    โปรดติดต่อเราตามอีเมลที่ให้ไว้ด้านล่าง
                    เราจะดำเนินการตรวจสอบและลบเนื้อหาที่ละเมิดโดยเร็วที่สุด
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">
                    เนื้อหาจากบุคคลที่สาม (Embedded Content)
                </h2>
                <p>
                    เว็บไซต์ของเราฝังวิดีโอจาก YouTube, โพสต์จาก Twitter/X และ
                    Instagram รวมถึงตัวอย่างเพลงหรือสื่ออื่น ๆ
                    ที่เผยแพร่ต่อสาธารณะโดยเจ้าของลิขสิทธิ์
                    เนื้อหาเหล่านี้ยังคงเป็นทรัพย์สินของเจ้าของลิขสิทธิ์แต่เพียงผู้เดียว
                    การฝังเนื้อหาดังกล่าวมีขึ้นเพื่อความสะดวกในการรับชมและเพื่อการส่งเสริมผลงานของศิลปินเท่านั้น
                    ไม่ได้มีเจตนาละเมิดลิขสิทธิ์แต่อย่างใด
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">ความถูกต้องของข้อมูล</h2>
                <p>
                    เราพยายามอย่างเต็มที่เพื่อให้ข้อมูลเกี่ยวกับประวัติสมาชิก,
                    ตารางกิจกรรม, ผลงาน, และข่าวสารต่าง ๆ
                    มีความถูกต้องและเป็นปัจจุบัน อย่างไรก็ตาม
                    เนื่องจากเป็นเว็บไซต์ที่ดำเนินการโดยแฟนคลับอาสาสมัคร
                    อาจมีความคลาดเคลื่อนหรือความล่าช้าในการอัปเดตได้ <strong
                        >เราไม่รับประกันความถูกต้องสมบูรณ์ของข้อมูล
                        และจะไม่รับผิดชอบต่อความเสียหายใด ๆ
                        ที่เกิดจากการใช้ข้อมูลดังกล่าว</strong
                    > สำหรับข้อมูลที่ต้องการความแน่นอนสูงสุด โปรดอ้างอิงจากช่องทางทางการของ
                    BNK48 หรือแหล่งข้อมูลจาก iAM เท่านั้น
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">ลิงก์ไปยังเว็บไซต์อื่น</h2>
                <p>
                    เว็บไซต์ของเราอาจมีลิงก์ไปยังเว็บไซต์ภายนอก เช่น
                    บัญชีทางการของ BNK48 ในโซเชียลมีเดีย, ร้านค้าอย่างทางการ
                    หรือบทความข่าว
                    เราไม่มีอำนาจควบคุมเนื้อหาและนโยบายความเป็นส่วนตัวของเว็บไซต์เหล่านั้น
                    การคลิกลิงก์ดังกล่าวถือเป็นความเสี่ยงของคุณเอง
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">
                    ไม่มีการเก็บข้อมูลส่วนบุคคลเพื่อการค้า
                </h2>
                <p>
                    เราไม่ขายข้อมูลผู้ใช้งานให้กับบุคคลที่สาม
                    และไม่ใช้ข้อมูลของคุณเพื่อวัตถุประสงค์ทางการค้าใด ๆ (เช่น
                    การตลาดแบบเจาะจงบุคคล) การเก็บข้อมูลผ่าน LocalStorage,
                    Analytics หรือ Supabase เป็นไปตามที่อธิบายไว้ใน <a
                        href="/privacy-policy">นโยบายความเป็นส่วนตัว</a
                    >
                    และใช้เพื่อการพัฒนาเว็บไซต์แฟนคลับเท่านั้น
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">การติดต่อเพื่อขอให้ลบเนื้อหา</h2>
                <p>
                    หากคุณเป็นเจ้าของลิขสิทธิ์หรือตัวแทน
                    และพบว่าเว็บไซต์นี้มีการใช้รูปภาพ, วิดีโอ,
                    หรือเนื้อหาที่ละเมิดสิทธิ์ของท่าน
                    โปรดแจ้งเราพร้อมหลักฐานดังต่อไปนี้:
                </p>
                <ul class="policy-list">
                    <li>ชื่อและข้อมูลติดต่อของคุณ (หรือตัวแทน)</li>
                    <li>
                        หลักฐานแสดงความเป็นเจ้าของลิขสิทธิ์ (เช่น ลิงก์ต้นฉบับ,
                        ทะเบียนลิขสิทธิ์)
                    </li>
                    <li>URL ที่พบเนื้อหาที่ละเมิดบนเว็บไซต์ของเรา</li>
                    <li>
                        คำรับรองว่าท่านสุจริตใจเชื่อว่าการใช้งานดังกล่าวไม่ได้รับอนุญาต
                    </li>
                </ul>
                <p>
                    ส่งข้อมูลมาที่อีเมล <a
                        href="mailto:teamniya.thfc1402@gmail.com"
                        >teamniya.thfc1402@gmail.com</a
                    >
                    เราจะดำเนินการลบหรือปิดการเข้าถึงเนื้อหาภายใน 7-14
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">
                    ข้อจำกัดความรับผิดชอบ (Disclaimer of Liability)
                </h2>
                <p>
                    เว็บไซต์นี้ให้บริการ “ตามที่เป็น” (AS IS)
                    โดยไม่มีการรับประกันใด ๆ ทั้งโดยชัดแจ้งหรือโดยนัย
                    รวมถึงแต่ไม่จำกัดเพียงการรับประกันความเหมาะสมต่อวัตถุประสงค์ใด
                    ๆ หรือการไม่ละเมิดสิทธิ์บุคคลที่สาม
                    ในกรณีที่เกิดความเสียหายอันเกิดจากการใช้เว็บไซต์
                    (รวมถึงมัลแวร์ที่อาจแฝงมากับเนื้อหาบุคคลที่สาม)
                    เราจะไม่รับผิดชอบ
                    เว้นแต่เป็นความเสียหายที่เกิดจากความประมาทเลินเล่ออย่างร้ายแรงของเรา
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">การเปลี่ยนแปลงข้อความกำกับดูแล</h2>
                <p>
                    เราขอสงวนสิทธิ์ในการแก้ไขคำชี้แจงนี้ได้ตลอดเวลา
                    โดยวันที่มีผลบังคับใช้จะแสดงไว้ด้านบนของหน้านี้
                    การใช้งานเว็บไซต์ต่อไปหลังจากมีการเปลี่ยนแปลงถือว่าคุณยอมรับข้อกำหนดที่แก้ไขใหม่
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">ติดต่อเรา</h2>
                <p>สำหรับข้อสงสัยทั่วไปหรือเรื่องลิขสิทธิ์:</p>
                <address>
                    อีเมล: <a href="mailto:teamniya.thfc1402@gmail.com"
                        >teamniya.thfc1402@gmail.com</a
                    >
                    <br />
                    เว็บไซต์: <a href="https://little-nemo-of-niya.vercel.app"
                        >https://little-nemo-of-niya.vercel.app</a
                    >
                    <br />
                    X: <a href="https://x.com/niyabnk48_thfc">@niyabnk48_thfc</a
                    >
                </address>
            </section>

            <p style="margin-top: 2rem; color: var(--c-content-secondary);">
                <strong
                    >“แฟนไซต์นี้สร้างขึ้นด้วยความรักที่มีต่อนีญ่าและ BNK48
                    ไม่มีเจตนาแอบอ้างเป็นทางการ
                    ขอเชิญร่วมเชียร์และสนับสนุนศิลปินอย่างถูกกฎหมาย”</strong
                >
            </p>
        </div>
    </div>
</MainLayout>
