---
// src/pages/cookies-policy.astro
import MainLayout from "../layouts/MainLayout.astro";

export interface Props {
title?: string;
}

const { title = "นโยบายการใช้คุกกี้ (Cookies Policy)" } = Astro.props;
---

<MainLayout title={title}>
    <div class="policy-page">
        <div class="policy-container container">
            <h1 class="policy-title">นโยบายการใช้คุกกี้ (Cookies Policy)</h1>
            <p class="last-updated">อัปเดตล่าสุด: 7 เมษายน 2569</p>

            <section class="policy-section">
                <h2 class="wp-block-heading">คุกกี้คืออะไร?</h2>
                <p>
                    คุกกี้ (Cookies)
                    คือไฟล์ข้อมูลขนาดเล็กที่เว็บไซต์ส่งไปยังเบราว์เซอร์ของคุณและถูกเก็บไว้ในอุปกรณ์
                    (คอมพิวเตอร์ สมาร์ทโฟน แท็บเล็ต)
                    เมื่อคุณเข้าเยี่ยมชมเว็บไซต์
                    คุกกี้ช่วยให้เว็บไซต์จดจำการตั้งค่า วิเคราะห์พฤติกรรม
                    และทำให้การใช้งานมีประสิทธิภาพมากขึ้น
                    โดยคุกกี้จะไม่สามารถใช้ระบุตัวตนบุคคลเฉพาะได้โดยตรงหากไม่มีข้อมูลเพิ่มเติม
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">ประเภทของคุกกี้ที่เราใช้</h2>
                <p>
                    เว็บไซต์ Niya BNK48 – Fan Website ใช้คุกกี้ประเภทต่าง ๆ
                    ดังต่อไปนี้:
                </p>
                <ul class="policy-list">
                    <li>
                        <strong>คุกกี้ที่จำเป็น (Strictly Necessary):</strong>
                        เว็บไซต์ของเราแทบไม่มีการใช้คุกกี้ที่จำเป็นต่อการทำงานขั้นพื้นฐาน
                        (เนื่องจากไม่มีระบบล็อกอินหรือตะกร้าสินค้า) อย่างไรก็ตาม Cloudflare
                        อาจใช้คุกกี้ด้านความปลอดภัย (เช่น __cfduid) ซึ่งถือว่าจำเป็นเพื่อป้องกันการโจมตีทางไซเบอร์
                    </li>
                    <li>
                        <strong>คุกกี้เพื่อการวิเคราะห์ (Analytics/Performance
                            Cookies):</strong> ใช้เก็บสถิติเกี่ยวกับจำนวนผู้เข้าใช้งาน พฤติกรรมการท่องเว็บ
                        (หน้าเว็บที่เข้าชมบ่อย, เวลาที่ใช้ในแต่ละหน้า, ลิงก์ที่คลิก)
                        โดยไม่ระบุตัวตน ซึ่งช่วยให้เราปรับปรุงเนื้อหาและโครงสร้างเว็บไซต์ให้ดีขึ้น
                    </li>
                    <li>
                        <strong>คุกกี้จากบุคคลที่สาม (Third-party Cookies):</strong> เกิดจากบริการภายนอกที่เราฝังไว้
                        เช่น วิดีโอ YouTube, โพสต์จาก
                        Twitter/X หรือ Instagram รวมถึงฟอนต์จาก Google Fonts
                    </li>
                </ul>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">
                    คุกกี้เพื่อการวิเคราะห์ (Analytics Cookies)
                </h2>
                <p>
                    เราใช้เครื่องมือวิเคราะห์จากบุคคลที่สามเพื่อทำความเข้าใจปริมาณการเข้าชมและพฤติกรรมของผู้ใช้:
                </p>
                <ul class="policy-list">
                    <li>
                        <strong>Google Analytics:</strong> ตั้งค่าคุกกี้เช่น _ga,
                        _gid, _gat_UA-xxxxxx-x เพื่อบันทึกข้อมูลการใช้งานแบบไม่ระบุตัวตน
                        อ่านเพิ่มเติมเกี่ยวกับคุกกี้ของ Google Analytics ได้ที่ <a
                            href="https://developers.google.com/analytics/devguides/collection/analyticsjs/cookie-usage"
                            target="_blank" rel="noopener noreferrer">Google Analytics Cookie Usage</a>
                    </li>
                    <li>
                        <strong>Vercel Analytics:</strong> ใช้คุกกี้ที่ไม่ระบุตัวตนเพื่อวัดประสิทธิภาพของหน้าเว็บและ
                        Core Web Vitals โดยไม่เก็บข้อมูลที่ระบุตัวบุคคลได้
                    </li>
                </ul>
                <p>
                    คุณสามารถปฏิเสธการเก็บข้อมูลของ Google Analytics
                    ได้โดยติดตั้ง <a href="https://tools.google.com/dlpage/gaoptout" target="_blank"
                        rel="noopener noreferrer">Google Analytics Opt-out Browser Add-on</a>
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">
                    คุกกี้จากบุคคลที่สาม (Third-party Cookies)
                </h2>
                <p>
                    เมื่อคุณเข้าชมหน้าที่มีการฝังเนื้อหาจากแพลตฟอร์มอื่น
                    เบราว์เซอร์ของคุณอาจรับคุกกี้จากโดเมนของบุคคลที่สามเหล่านั้น
                    เราไม่สามารถควบคุมการตั้งค่าคุกกี้ดังกล่าวได้โดยตรง
                    แต่คุณสามารถจัดการได้ผ่านการตั้งค่าเบราว์เซอร์ของคุณ
                    ตัวอย่างบริการที่อาจตั้งค่าคุกกี้:
                </p>
                <ul class="policy-list">
                    <li>
                        <strong>YouTube:</strong> คุกกี้เช่น PREF, VISITOR_INFO1_LIVE,
                        YSC เพื่อจดจำการตั้งค่าผู้ใช้และสถิติวิดีโอ
                    </li>
                    <li>
                        <strong>Twitter/X:</strong> คุกกี้เช่น personalization_id,
                        ct0 เพื่อการแสดงผลเนื้อหาและการโฆษณา
                    </li>
                    <li>
                        <strong>Instagram (Meta):</strong> คุกกี้เช่น sessionid, csrftoken,
                        ig_did เพื่อรักษาสถานะการล็อกอินและวิเคราะห์
                    </li>
                    <li>
                        <strong>Google Fonts:</strong> แม้ Google Fonts จะไม่ใช้คุกกี้
                        แต่มีการร้องขอข้อมูล IP address ของผู้ใช้เพื่อส่งมอบฟอนต์
                        ซึ่งอยู่ภายใต้นโยบายความเป็นส่วนตัวของ Google
                    </li>
                </ul>
                <p>
                    โปรดตรวจสอบนโยบายคุกกี้ของบริการเหล่านั้นสำหรับข้อมูลเพิ่มเติม:
                    <a href="https://policies.google.com/technologies/cookies" target="_blank"
                        rel="noopener noreferrer">Google</a>, <a
                        href="https://help.twitter.com/en/rules-and-policies/twitter-cookies" target="_blank"
                        rel="noopener noreferrer">Twitter</a>, <a href="https://help.instagram.com/1896641480634370"
                        target="_blank" rel="noopener noreferrer">Instagram</a>
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">
                    Local Storage เกี่ยวข้องกับคุกกี้หรือไม่?
                </h2>
                <p>
                    แม้ LocalStorage จะเป็นเทคโนโลยีที่แตกต่างจากคุกกี้
                    (เก็บข้อมูลได้มากกว่าและไม่ถูกส่งไปยังเซิร์ฟเวอร์อัตโนมัติ)
                    แต่เว็บไซต์ของเราใช้ LocalStorage
                    เพื่อวัตถุประสงค์ที่คล้ายคลึงกัน เช่น
                    การจดจำผลเกมและแผนกิจกรรม เราไม่ได้ถือว่า LocalStorage
                    เป็นคุกกี้ แต่เพื่อความโปร่งใส ขอแจ้งว่าคุณสามารถลบข้อมูล
                    LocalStorage ได้โดยอิสระผ่านการตั้งค่าเบราว์เซอร์ (ส่วน
                    "ล้างข้อมูลการจัดเก็บไซต์")
                    โดยการดำเนินการนี้จะไม่ส่งผลกระทบต่อคุกกี้โดยตรง
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">การจัดการและลบ Cookies</h2>
                <p>
                    คุณสามารถควบคุมหรือปิดการใช้งานคุกกี้ได้ผ่านการตั้งค่าเบราว์เซอร์ของคุณ
                    ด้านล่างเป็นลิงก์คำแนะนำสำหรับเบราว์เซอร์ที่ได้รับความนิยม:
                </p>
                <ul class="policy-list">
                    <li>
                        <a href="https://support.google.com/chrome/answer/95647" target="_blank"
                            rel="noopener noreferrer">Google Chrome</a>
                    </li>
                    <li>
                        <a href="https://support.mozilla.org/th/kb/clear-cookies-and-site-data-firefox" target="_blank"
                            rel="noopener noreferrer">Mozilla Firefox</a>
                    </li>
                    <li>
                        <a href="https://support.apple.com/th-th/guide/safari/sfri11471/mac" target="_blank"
                            rel="noopener noreferrer">Safari</a>
                    </li>
                    <li>
                        <a href="https://support.microsoft.com/en-us/microsoft-edge/delete-cookies-in-microsoft-edge-63947406-40ac-c3b8-57b9-2a946a29ae09"
                            target="_blank" rel="noopener noreferrer">Microsoft Edge</a>
                    </li>
                </ul>
                <p>
                    โปรดทราบว่าการปิดใช้งานคุกกี้ทั้งหมดอาจทำให้ฟีเจอร์บางอย่างของเว็บไซต์ทำงานไม่สมบูรณ์
                    เช่น การเล่นวิดีโอ YouTube หรือการเห็นโพสต์จาก Instagram
                    ที่ฝังไว้
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">การเปลี่ยนแปลงนโยบายคุกกี้</h2>
                <p>
                    เราอาจปรับปรุงนโยบายคุกกี้เป็นครั้งคราวเพื่อสะท้อนถึงการเปลี่ยนแปลงของเทคโนโลยีหรือข้อกำหนดทางกฎหมาย
                    โดยวันที่มีผลบังคับใช้จะแสดงไว้ที่ด้านบนของหน้านี้
                    หากมีการเปลี่ยนแปลงที่มีนัยสำคัญ
                    เราจะแจ้งให้ทราบผ่านประกาศบนเว็บไซต์
                </p>
            </section>

            <section class="policy-section">
                <h2 class="wp-block-heading">ติดต่อเรา</h2>
                <p>
                    หากคุณมีคำถามเพิ่มเติมเกี่ยวกับการใช้คุกกี้ของเรา
                    กรุณาติดต่อ:
                </p>
                <address>
                    อีเมล: <a href="mailto:teamniya.thfc1402@gmail.com">teamniya.thfc1402@gmail.com</a>
                    <br />
                    เว็บไซต์: <a
                        href="https://little-nemo-of-niya.vercel.app">https://little-nemo-of-niya.vercel.app</a>
                    <br />
                    X: <a href="https://x.com/niyabnk48_thfc">@niyabnk48_thfc</a>
                </address>
            </section>
        </div>
    </div>
</MainLayout>