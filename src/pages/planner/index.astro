---
// src/pages/planner/index.astro
import MainLayout from "@/app/layouts/MainLayout.astro";
import {
    getPlannerEvents,
    getRankingEvents,
} from "@/features/events/eventEngine";
import PlannerCard from "@/features/planner/ui/PlannerCard.astro";
import "@/shared/styles/planner.scss";

const ALL_PLANNER_EVENTS = await getPlannerEvents();
const MAIN_PLANNERS = ALL_PLANNER_EVENTS.filter(
    (e) => !e.features.planner?.href,
);
const FAN_PROJECTS = ALL_PLANNER_EVENTS.filter((e) => e.features.planner?.href);

const RANKING_EVENTS = await getRankingEvents();

const title = "Planners - Niya BNK48";
const description =
    "เลือกอีเวนต์แล้ววางแผนตาราง กิจกรรม และเมมเบอร์ที่อยากเจอ — เครื่องมือสำหรับแฟนคลับ";
---

<MainLayout title={title} description={description}>
    <div class="planner-hub" aria-labelledby="planner-hub-heading">
        <!-- ── Event Planners ── -->
        <header class="planner-hub__intro">
            <div>
                <h1 id="planner-hub-heading" class="planner-hub__title mb-2">
                    Event Planners
                </h1>
                <p class="planner-hub__lead mb-0">
                    แพลนเนอร์เพื่อจัดตารางเวลาและสรุปแผนกิจกรรม
                </p>
            </div>
        </header>
        <div class="mb-5 ranking-ad" aria-labelledby="planner-heading">
            {
                MAIN_PLANNERS.length === 0 ? (
                    <p class="planner-hub__empty mb-0">
                        ยังไม่มีแพลนเนอร์ให้เลือกในขณะนี้ —
                        โปรดกลับมาดูใหม่ภายหลัง
                    </p>
                ) : (
                    <section class="p-0">
                        <div class="row row-cols-1 row-cols-sm-2 g-4">
                            {MAIN_PLANNERS.map((event) => (
                                <div class="col d-flex justify-content-center">
                                    <article
                                        class="planner-card__article d-flex flex-column h-100 overflow-hidden"
                                        style={`--planner-accent: ${event.primaryColor};`}
                                    >
                                        <a
                                            class="planner-card__media"
                                            href={`/planner/${event.slug}`}
                                            aria-label={`Open planner for ${event.name}`}
                                        >
                                            <img
                                                src={
                                                    event.features.planner
                                                        ?.listingImage ??
                                                    event.features.planner
                                                        ?.heroImage
                                                }
                                                alt={event.name}
                                                width="960"
                                                height="540"
                                                loading="lazy"
                                                decoding="async"
                                            />
                                        </a>
                                        <div class="planner-card__body d-flex flex-column flex-grow-1">
                                            <h2 class="h6 planner-card__title">
                                                <a
                                                    href={`/planner/${event.slug}`}
                                                >
                                                    {event.name}
                                                </a>
                                            </h2>
                                            <p class="planner-card__desc">
                                                {
                                                    event.features.planner
                                                        ?.description
                                                }
                                            </p>
                                            <div class="planner-card__actions d-flex flex-wrap align-items-center">
                                                <a
                                                    class="btn planner-card__cta"
                                                    href={`/planner/${event.slug}`}
                                                >
                                                    เปิดแพลนเนอร์
                                                    <i
                                                        class="fa-solid fa-arrow-right arrow-icon ms-1"
                                                        aria-hidden="true"
                                                    />
                                                </a>
                                                <a
                                                    class="planner-card__official d-inline-flex align-items-center position-relative"
                                                    href={
                                                        event.features.planner
                                                            ?.officialLink
                                                    }
                                                    target="_blank"
                                                    rel="noopener noreferrer"
                                                >
                                                    ข้อมูลทางการ
                                                    <i
                                                        class="fa-solid fa-arrow-up-right-from-square"
                                                        aria-hidden="true"
                                                    />
                                                    <span class="sr-only">
                                                        (opens in new window)
                                                    </span>
                                                </a>
                                            </div>
                                        </div>
                                    </article>
                                </div>
                            ))}
                        </div>
                    </section>
                )
            }
        </div>

        <!-- ── Fan's Projects ── -->
