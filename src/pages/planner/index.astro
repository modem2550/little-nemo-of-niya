        <!-- ── Ranking Game Shortcut Ad ───────────────────────────────── -->
        <header class="planner-hub__intro">
            <div>
                <h2 id="ranking-game-ad-heading" class="planner-hub__title mb-2">
                    Games
                </h2>
                <p class="planner-hub__lead mb-0">
                    เล่นเกมจับคู่เมมเบอร์ที่คุณชอบแล้วดูว่าใครติดอันดับ
                    Top&nbsp;10 ของคุณ
                </p>
            </div>
        </header>
        <div class="mb-5 ranking-ad" aria-labelledby="ranking-ad-heading">
            <section class="ranking-ad__grid" aria-label="Ranking game variants">
                <div class="row row-cols-1 row-cols-sm-2 g-4">
                    {
                    RANKING_EVENTS.map((ev) => (
                    <div class="col d-flex justify-content-center">
                        <article class="planner-card__article d-flex flex-column h-100 overflow-hidden"
                            style={`--planner-accent: ${ev.primaryColor};`}>
                            <a class="planner-card__media" href={`/ranking/${ev.slug}`} aria-label={`Play ${ev.name}
                                ranking game`}>
                                {ev.features.ranking?.listingImage && (
                                <img src={ ev.features.ranking .listingImage } alt={ev.name} width="960" height="540"
                                    loading="lazy" decoding="async" />
                                )}
                                <span class="planner-card__badge" aria-hidden="false">
                                    <i class="fa-solid fa-gamepad" aria-hidden="true" />
                                    <span>
                                        {ev.features.ranking?.rounds}{" "}
                                        รอบ
                                    </span>
                                </span>
                            </a>
                            <div class="planner-card__body d-flex flex-column flex-grow-1">
                                <h3 class="h6 planner-card__title">
                                    <a href={`/ranking/${ev.slug}`}>
                                        {ev.name}
                                    </a>
                                </h3>
                                <p class="planner-card__desc">
                                    {ev.features.ranking?.description}
                                </p>
                                <div class="planner-card__actions d-flex flex-wrap align-items-center">
                                    <a class="btn btn-sm btn-primary btn-rounded fw-700 planner-card__cta"
                                        href={`/ranking/${ev.slug}`}>
                                        เล่นเกม
                                        <i class="fa-solid fa-arrow-right arrow-icon ms-1" aria-hidden="true" />
                                    </a>
                                </div>
                            </div>
                        </article>
                    </div>
                    ))
                    }
                </div>
            </section>
        </div>
    </div>
</MainLayout>
<style>
    .container {
        max-width: 1320px !important;
        margin: 0 auto;
    }
</style>