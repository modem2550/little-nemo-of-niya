    </script>
</MainLayout>
<style is:global>
    body {
        background-color: #000;
    }
    /* ทำให้ header transparent เฉพาะหน้า 404 */
    header {
        display: none;
    }


    .wrap {
        width: auto;
        height: 100vh;
        min-height: 600px;
        position: relative;
        margin: 0 auto;
        overflow: hidden;
    }

    @supports (-webkit-touch-callout: none) {
        .wrap {
            height: -webkit-fill-available;
        }
    }

    .info {
        position: absolute;
        top: 0;
        left: 0;
        z-index: 1;
        width: 100%;
        padding: 36px 24px 64px;
        text-align: center;
        color: #fff;
        text-shadow: 0px 0px 12px rgba(0, 0, 0, 0.25);
    }

    .video-wrap {
        width: 100%;
        height: 100%;
        font-size: 0;
    }

    .video-wrap video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .speaker-svg {
        width: 16px;
        height: 16px;
        margin-top: -2px;
        display: inline-block;
        vertical-align: middle;
    }

    @media (min-width: 576px) {
        .wrap {
            aspect-ratio: 9/16;
            margin: 48px auto;
            height: calc(100vh - 96px);
            border-radius: 8px;
        }
    }

    .song {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 24px;
        text-align: center;
        color: #fff;
    }
</style>