            class extends HTMLElement {
                constructor() {
                    super();
                    try {
                        const r = JSON.parse(this.dataset.props ?? "{}"),
                            n = JSON.parse(this.dataset.params ?? "{}");
                        g({
                            ...r,
                            disableAutoTrack: !0,
                            framework: "astro",
                            basePath: k(),
                            beforeSend: window.webAnalyticsBeforeSend,
                        });
                        const t = this.dataset.pathname;
                        p({
                            route: b(t ?? "", n),
                            path: t,
