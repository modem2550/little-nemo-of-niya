---
import MainLayout from "../layouts/MainLayout.astro";

const ICON_SPEAKER_ON = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 512" fill="currentColor" width="16" height="16" class="ms-2 speaker-svg"><path d="M533.6 32.5C598.5 85.2 640 165.8 640 256s-41.5 170.7-106.4 223.5c-10.3 8.4-25.4 6.8-33.8-3.5s-6.8-25.4 3.5-33.8C557.5 398.2 592 331.2 592 256s-34.5-142.2-88.7-186.3c-10.3-8.4-11.8-23.5-3.5-33.8s23.5-11.8 33.8-3.5zM473.1 107c43.2 35.2 70.9 88.9 70.9 149s-27.7 113.8-70.9 149c-10.3 8.4-25.4 6.8-33.8-3.5s-6.8-25.4 3.5-33.8C475.3 341.3 496 301.1 496 256s-20.7-85.3-53.2-111.8c-10.3-8.4-11.8-23.5-3.5-33.8s23.5-11.8 33.8-3.5zm-60.5 74.5C434.1 199.1 448 225.9 448 256s-13.9 56.9-35.4 74.5c-10.3 8.4-25.4 6.8-33.8-3.5s-6.8-25.4 3.5-33.8C393.1 284.4 400 271 400 256s-6.9-28.4-17.7-37.3c-10.3-8.4-11.8-23.5-3.5-33.8s23.5-11.8 33.8-3.5zM301.1 34.8C312.6 40 320 51.4 320 64l0 384c0 12.6-7.4 24-18.9 29.2s-25 3.1-34.4-5.3L131.8 352 64 352c-35.3 0-64-28.7-64-64l0-64c0-35.3 28.7-64 64-64l67.8 0L266.7 40.1c9.4-8.4 22.9-10.4 34.4-5.3z"/></svg>`;
const ICON_SPEAKER_OFF = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill="currentColor" width="16" height="16" class="ms-2 speaker-svg"><path d="M301.1 34.8C312.6 40 320 51.4 320 64l0 384c0 12.6-7.4 24-18.9 29.2s-25 3.1-34.4-5.3L131.8 352 64 352c-35.3 0-64-28.7-64-64l0-64c0-35.3 28.7-64 64-64l67.8 0L266.7 40.1c9.4-8.4 22.9-10.4 34.4-5.3zM425 167l55 55 55-55c9.4-9.4 24.6-9.4 33.9 0s9.4 24.6 0 33.9l-55 55 55 55c9.4 9.4 9.4 24.6 0 33.9s-24.6 9.4-33.9 0l-55-55-55 55c-9.4 9.4-24.6 9.4-33.9 0s-9.4-24.6 0-33.9l55-55-55-55c-9.4-9.4-9.4-24.6 0-33.9s24.6-9.4 33.9 0z"/></svg>`;
---

<MainLayout title="404 - Not Found">
    <div class="page-404">
        <div class="wrap">
            <div class="info">
                <h1 class="fs-12 fw-400 mb-2">404 PAGE NOT FOUND</h1>
                <p class="fw-700 mb-3">อุ๊ปสสส เหมือนหน้านี้จะไม่มีนะ <br />งั้นพักสิ่งที่น่าสนใจสักครู่ 😝</p>
                <a class="btn btn-sm btn-outline-light btn-rounded fs-12 fw-500 d-inline-block me-1" href="/">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" fill="currentColor" class="me-2 speaker-svg">
                        <path d="M9.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.2 288 416 288c17.7 0 32-14.3 32-32s-14.3-32-32-32l-306.7 0L214.6 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z"/>
                    </svg>
                    back to home
                </a>
                <button type="button" class="btn btn-sm btn-outline-light btn-rounded fs-12 fw-500 d-inline-block ms-1" id="muteButton">
                    play with sound
                    <Fragment set:html={ICON_SPEAKER_ON} />
                </button>
            </div>

            <div class="video-wrap">
                <video id="myVideo" width="720" height="1080" playsinline autoplay loop muted>
                    <source src="/video/404-Video-naya.mp4" type="video/mp4" />
                </video>
            </div>
        </div>
    </div>

    <footer class="page-404__credit text-center py-4">
        <p class="mb-0">inspyration From <a href="https://emmafans.vercel.app/" class="page-404__credit-link">emmafans By withmywish*</a></p>
    </footer>

    <script>
        const video  = document.getElementById('myVideo') as HTMLVideoElement;
        const btn    = document.getElementById('muteButton') as HTMLButtonElement;

        const ICON_ON  = `play with sound<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 512" fill="currentColor" width="16" height="16" class="ms-2 speaker-svg"><path d="M533.6 32.5C598.5 85.2 640 165.8 640 256s-41.5 170.7-106.4 223.5c-10.3 8.4-25.4 6.8-33.8-3.5s-6.8-25.4 3.5-33.8C557.5 398.2 592 331.2 592 256s-34.5-142.2-88.7-186.3c-10.3-8.4-11.8-23.5-3.5-33.8s23.5-11.8 33.8-3.5zM473.1 107c43.2 35.2 70.9 88.9 70.9 149s-27.7 113.8-70.9 149c-10.3 8.4-25.4 6.8-33.8-3.5s-6.8-25.4 3.5-33.8C475.3 341.3 496 301.1 496 256s-20.7-85.3-53.2-111.8c-10.3-8.4-11.8-23.5-3.5-33.8s23.5-11.8 33.8-3.5zm-60.5 74.5C434.1 199.1 448 225.9 448 256s-13.9 56.9-35.4 74.5c-10.3 8.4-25.4 6.8-33.8-3.5s-6.8-25.4 3.5-33.8C393.1 284.4 400 271 400 256s-6.9-28.4-17.7-37.3c-10.3-8.4-11.8-23.5-3.5-33.8s23.5-11.8 33.8-3.5zM301.1 34.8C312.6 40 320 51.4 320 64l0 384c0 12.6-7.4 24-18.9 29.2s-25 3.1-34.4-5.3L131.8 352 64 352c-35.3 0-64-28.7-64-64l0-64c0-35.3 28.7-64 64-64l67.8 0L266.7 40.1c9.4-8.4 22.9-10.4 34.4-5.3z"/></svg>`;
        const ICON_OFF = `mute sound<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" fill="currentColor" width="16" height="16" class="ms-2 speaker-svg"><path d="M301.1 34.8C312.6 40 320 51.4 320 64l0 384c0 12.6-7.4 24-18.9 29.2s-25 3.1-34.4-5.3L131.8 352 64 352c-35.3 0-64-28.7-64-64l0-64c0-35.3 28.7-64 64-64l67.8 0L266.7 40.1c9.4-8.4 22.9-10.4 34.4-5.3zM425 167l55 55 55-55c9.4-9.4 24.6-9.4 33.9 0s9.4 24.6 0 33.9l-55 55 55 55c9.4 9.4 9.4 24.6 0 33.9s-24.6 9.4-33.9 0l-55-55-55 55c-9.4 9.4-24.6 9.4-33.9 0s-9.4-24.6 0-33.9l55-55-55-55c-9.4-9.4-9.4-24.6 0-33.9s24.6-9.4 33.9 0z"/></svg>`;

        btn?.addEventListener('click', () => {
        video.muted = !video.muted;
        if (!video.muted && video.paused) video.play();
        btn.innerHTML = video.muted ? ICON_ON : ICON_OFF;
        });
    </script>
</MainLayout>

<style is:global>
    body { background-color: var(--c-dark); }
    header { display: none; }

    .page-404__credit {
        font-size: var(--fs-small);
        opacity: 0.72;
        color: color-mix(in srgb, var(--c-light) 88%, transparent);
    }

    .page-404__credit-link {
        color: var(--c-light) !important;
        font-weight: 700;
        margin-left: 0.2em;
    }

    .page-404__credit-link:hover {
        color: var(--c-primary) !important;
    }

    .wrap {
        width: auto;
        height: 100vh;
        min-height: 600px;
        position: relative;
        margin: 0 auto;
        overflow: hidden;
    }

    @supports (-webkit-touch-callout: none) {
        .wrap { height: -webkit-fill-available; }
    }

    @media (min-width: 576px) {
        .wrap {
        aspect-ratio: 9/16;
        margin: 48px auto;
        height: calc(100vh - 96px);
        border-radius: 8px;
        }
    }

    .info {
        position: absolute;
        top: 0; left: 0;
        z-index: 1;
        width: 100%;
        padding: 36px 24px 64px;
        text-align: center;
        color: #fff;
        text-shadow: 0 0 12px rgba(0,0,0,.25);
    }

    .fs-12 { font-size: 12px; }

    .video-wrap { width: 100%; height: 100%; font-size: 0; }
    .video-wrap video { width: 100%; height: 100%; object-fit: cover; }

    .speaker-svg {
        width: 16px; height: 16px;
        margin-top: -2px;
        display: inline-block;
        vertical-align: middle;
    }
</style>