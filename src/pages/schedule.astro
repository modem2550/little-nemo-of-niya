---
import MainLayout from '../layouts/MainLayout.astro';
import EventCard from '../components/EventCard.astro';
import { getSupabase } from "../lib/supabase.server";
import { categorizeEvents } from '../lib/dateUtils';
import type { Event } from '../types/event';

const supabase = getSupabase();

// ดึงข้อมูลจาก Supabase
const { data: events, error } = await supabase
  .from('event_data')
  .select('*')
  .order('date', { ascending: false });

if (error) {
  console.error('Error fetching events:', error);
}

// แยกประเภทงานโดยใช้ utility function
const { upcoming, past } = categorizeEvents(events || []);

// นับจำนวนกิจกรรม
const upcomingCount = upcoming.length;
const pastCount = past.length;
---

<MainLayout title="Schedule - Niya BNK48's">
  <!-- Header -->
  <div class="schedule-header">
    <header>
      <h1 class="text-center fw-800 h1">
        <strong>Niya BNK48's Schedule</strong>
      </h1>
      <p class="text-center fw-600 mb-0 subtitle">
        ตารางงานและกิจกรรมของนีญ่า
      </p>
    </header>
  </div>
  
  <main class="page-main">
    <!-- Upcoming Events Section -->
    <section 
      id="upcoming-events-section" 
      class="events-section"
      aria-labelledby="upcoming-heading"
    >
      <h2 id="upcoming-heading" class="h1 text-center fw-800 h-sec mb-0">
        <strong>Upcoming Events</strong>
      </h2>
      <p class="text-center mb-5 text-muted">
        กิจกรรมที่จะถึง
        {upcomingCount > 0 && (
          <span class="event-count">({upcomingCount})</span>
        )}
      </p>

      {upcoming.length > 0 ? (
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
          {upcoming.map((event) => (
            <div class="col d-flex justify-content-center">
              <EventCard event={event} isPast={false} />
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <svg class="icon" width="48" height="48" aria-hidden="true">
            <use href="#icon-calendar"></use>
          </svg>
          <p class="text-muted">ยังไม่มีกิจกรรมประกาศในขณะนี้</p>
        </div>
      )}
    </section>

    <!-- Back Home Button -->
    <div class="text-center my-5">
      <a class="btn btn-primary btn-rounded fw-600 px-4" href="/"> 
        <div class="d-flex align-items-center">
          <strong>กลับหน้าหลัก</strong>
          <svg class="icon arrow-svg ms-2" width="24" height="24" aria-hidden="true">
            <use href="#icon-arrow-right"></use>
          </svg>
        </div>
      </a>
    </div>

    <!-- Past Events Section -->
    <section 
      id="past-events-section" 
      class="events-section"
      aria-labelledby="past-heading"
    >
      <h2 id="past-heading" class="h-sec h1 text-center mb-0">
        Past Events
      </h2>
      <p class="text-center mb-5 text-muted">
        กิจกรรมที่จัดไปแล้ว
        {pastCount > 0 && (
          <span class="event-count">({pastCount})</span>
        )}
      </p>
      
      {past.length > 0 ? (
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4 event-past">
          {past.map((event) => (
            <div class="col d-flex justify-content-center">
              <EventCard event={event} isPast={true} variant="compact" />
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p class="text-muted">ยังไม่มีกิจกรรมที่ผ่านมา</p>
        </div>
      )}
    </section>
  </main>
</MainLayout>

<style>
  .schedule-header {
    margin-top: 108px;
    background: var(--c-primary);
    padding: 30px 0;
    color: white;
  }
  
  .subtitle {
    font-size: 18px;
  }
  
  .events-section {
    padding: 2rem 0;
  }
  
  .event-count {
    opacity: 0.7;
    font-size: 0.9em;
  }
  
  .empty-state {
    text-align: center;
    padding: 4rem 0;
  }
  
  .empty-state .icon {
    opacity: 0.3;
    margin-bottom: 1rem;
  }
  
  .arrow-svg {
    transform: rotate(-45deg);
    height: 1em;
    vertical-align: -0.125em;
  }
</style>

<script>
  // Minimal client-side enhancements
  document.addEventListener('DOMContentLoaded', () => {
    // Scroll to top button
    const scrollBtn = document.createElement('button');
    scrollBtn.id = 'scrollToTop';
    scrollBtn.className = 'btn btn-outline-secondary btn-sm';
    scrollBtn.innerHTML = '↑';
    scrollBtn.title = 'กลับสู่ด้านบน';
    scrollBtn.setAttribute('aria-label', 'กลับสู่ด้านบน');
    scrollBtn.style.cssText = `
      position: fixed;
      bottom: 20px;
      right: 20px;
      z-index: 1000;
      opacity: 0;
      transition: opacity 0.3s;
      pointer-events: none;
    `;
    document.body.appendChild(scrollBtn);
    
    // Show/hide on scroll
    window.addEventListener('scroll', () => {
      if (window.scrollY > 300) {
        scrollBtn.style.opacity = '1';
        scrollBtn.style.pointerEvents = 'auto';
      } else {
        scrollBtn.style.opacity = '0';
        scrollBtn.style.pointerEvents = 'none';
      }
    });
    
    // Scroll to top on click
    scrollBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>