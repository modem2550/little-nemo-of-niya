---
import MainLayout from '../layouts/MainLayout.astro';
import EventCard from '../components/EventCard.astro';
import { getSupabase } from '../lib/supabase.server';
import { categorizeEvents } from '../lib/dateUtils';

// ── Data ──────────────────────────────────────────────────────────────────────

const { data: rawEvents, error } = await getSupabase()
  .from('event_data')
  .select('*')
  .order('date', { ascending: false });

if (error) console.error('Error fetching events:', error);

// ── Process ───────────────────────────────────────────────────────────────────

function toSlug(text: string) {
  return text.toLowerCase().trim().replace(/\s+/g, '-').replace(/[()]/g, '').replace(/[^a-z0-9-]/g, '');
}

const eventsWithSlug = (rawEvents ?? []).map((event) => ({
  ...event,
  generated_slug: `${toSlug(event.title || 'event')}-${String(event.id || '0000').substring(0, 8)}`,
}));

const { upcoming, past } = categorizeEvents(eventsWithSlug);
---

<MainLayout title="Schedule - Niya BNK48's">
  <!-- Header -->
  <div class="schedule-header">
    <h1 class="text-center fw-800 h1"><strong>Niya BNK48's Schedule</strong></h1>
    <p class="text-center fw-600 mb-0 subtitle">ตารางงานและกิจกรรมของนีญ่า</p>
  </div>

  <main class="page-main">
    <!-- Upcoming -->
    <section id="upcoming-events-section" class="events-section" aria-labelledby="upcoming-heading">
      <h2 id="upcoming-heading" class="h1 text-center fw-800 h-sec mb-0"><strong>Upcoming Events</strong></h2>
      <p class="text-center mb-5 text-muted">
        กิจกรรมที่จะถึง
        {upcoming.length > 0 && <span class="event-count">({upcoming.length})</span>}
      </p>

      {upcoming.length > 0 ? (
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
          {upcoming.map((event) => (
            <div class="col d-flex justify-content-center">
              <EventCard event={event} isPast={false} />
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <svg class="icon" width="48" height="48" aria-hidden="true"><use href="#icon-calendar"></use></svg>
          <p class="text-muted">ยังไม่มีกิจกรรมประกาศในขณะนี้</p>
        </div>
      )}
    </section>

    <!-- Back home -->
    <div class="text-center my-5">
      <a class="btn btn-primary btn-rounded fw-600 px-4" href="/">
        <strong>กลับหน้าหลัก</strong>
        <i class="fa-solid fa-arrow-right arrow-svg ms-1"></i>
      </a>
    </div>

    <!-- Past -->
    <section id="past-events-section" class="events-section" aria-labelledby="past-heading">
      <h2 id="past-heading" class="h-sec h1 text-center mb-0">Past Events</h2>
      <p class="text-center mb-5 text-muted">
        กิจกรรมที่จัดไปแล้ว
        {past.length > 0 && <span class="event-count">({past.length})</span>}
      </p>

      {past.length > 0 ? (
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4 event-past">
          {past.map((event) => (
            <div class="col d-flex justify-content-center">
              <EventCard event={event} isPast={true} variant="compact" />
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p class="text-muted">ยังไม่มีกิจกรรมที่ผ่านมา</p>
        </div>
      )}
    </section>
  </main>
</MainLayout>

<style>
  .schedule-header {
    margin-top: 108px;
    background: var(--c-primary);
    padding: 30px 0;
    color: white;
  }

  .subtitle { font-size: 18px; }
  .events-section { padding: 2rem 0; }
  .event-count { opacity: 0.7; font-size: 0.9em; }

  .empty-state {
    text-align: center;
    padding: 4rem 0;
  }
  .empty-state .icon {
    opacity: 0.3;
    margin-bottom: 1rem;
  }

  .arrow-svg {
    transform: rotate(-45deg);
    height: 1em;
    vertical-align: -0.125em;
  }
</style>

<script>
  // Scroll-to-top button
  const btn = Object.assign(document.createElement('button'), {
    id:        'scrollToTop',
    className: 'btn btn-outline-secondary btn-sm',
    innerHTML: '↑',
    title:     'กลับสู่ด้านบน',
  });
  btn.setAttribute('aria-label', 'กลับสู่ด้านบน');
  btn.style.cssText = 'position:fixed;bottom:20px;right:20px;z-index:1000;opacity:0;transition:opacity .3s;pointer-events:none';
  document.body.appendChild(btn);

  const setVisible = (v: boolean) => {
    btn.style.opacity       = v ? '1' : '0';
    btn.style.pointerEvents = v ? 'auto' : 'none';
  };

  window.addEventListener('scroll', () => setVisible(window.scrollY > 300));
  btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>