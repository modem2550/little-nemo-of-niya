---
// src/components/EventPlanner.astro
import "@/shared/styles/planner.scss";
import type {
    ActivityConfig,
    DayConfig,
    PriceConfig,
    ScheduleEntry,
} from "@/features/planner/logic/plannerUtils";

import type { Member as MemberRow } from "@/types/member";
import { Image } from "astro:assets";

interface Props {
    eventSlug: string;
    eventName: string;
    pageTitle?: string;
    officialLink: string;
    storageKey: string;
    heroImage: string;
    primaryColor: string;
    primaryHover: string;
    prices: PriceConfig;
    days: DayConfig[];
    activities: ActivityConfig[];
    members: MemberRow[];
    schedule: ScheduleEntry[];
}

const {
    eventName,
    officialLink,
    storageKey,
    heroImage,
    prices,
    days,
    activities,
    members,
    schedule,
} = Astro.props;

const TEAM_COLOR: Record<string, string> = {
    "team biii": "var(--c-biii)",
    "team nv": "var(--c-nv)",
    "team c": "var(--c-c)",
    trainee: "var(--c-trainee)",
};

function resolveTeamColor(team?: string, brand?: string) {
    const normalized = (team ?? "").trim().toLowerCase();
    if (TEAM_COLOR[normalized]) return TEAM_COLOR[normalized];

    // Fallback by brand if team label is unexpected/missing.
    return brand === "CGM48" ? "var(--c-cgm)" : "var(--c-bnk)";
}

const cfg = JSON.stringify({ activities, days, storageKey, schedule, prices });
---

<div
    class="sf-hero sf-hero--cover"
    style={`--sf-hero-image: url('${heroImage}')`}
>
    {/* Hidden img to help browser discovery and LCP */}
    <img
        src={heroImage}
        alt=""
        {...{ fetchpriority: "high" }}
        style="display: none;"
    />
    <div class="sf-hero__overlay"></div>
    <div class="container sf-hero__container">
        <div class="sf-hero-card slide-up">
            <p class="sf-hero__eyebrow">BNK48 & CGM48</p>
            <h1 class="sf-hero__title">
                {eventName}
            </h1>
            <div class="sf-hero__meta">
                <span>รายละเอียด&nbsp;:&nbsp;</span>
                <a href={officialLink} class="sf-hero__link" target="_blank">
                    BNK48 & CGM48 Official <i
                        class="fa-solid fa-arrow-up-right-from-square ms-1 u-fs-10"
                    ></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- TABS -->
<div class="sf-tabs-wrap">
    <div class="container px-3">
        <div class="sf-tabs d-flex justify-content-center overflow-auto">
            {
                [
                    { id: "members", icon: "fa-user-group", label: "Members" },
                    { id: "planner", icon: "fa-calendar", label: "Planner" },
                    { id: "happening", icon: "fa-clock", label: "Now" },
                    { id: "summary", icon: "fa-list-check", label: "Summary" },
                ].map(({ id, icon, label }) => (
                    <button
                        class={`sf-tab${id === "members" ? " active" : ""}`}
                        data-tab={id}
                    >
                        <i class={`fa-solid ${icon}`} />
                        {label}
                        {id === "happening" && (
                            <span
                                class="tab-badge tab-badge--live d-none"
                                id="nowBadge"
                            >
                                LIVE
                            </span>
                        )}
                        {id === "summary" && (
                            <span class="tab-badge d-none" id="summaryBadge">
                                0
                            </span>
                        )}
                    </button>
                ))
            }
        </div>
    </div>
</div>

<!-- TAB: MEMBERS -->
<div class="sf-panel active" id="panel-members">
    <div class="sf-section-shell mx-auto p-4 pb-0">
        <div
            class="d-flex flex-column gap-3 p-4 rounded-4 filter-box mb-4 mx-auto"
        >
            <div class="row g-2" id="mBrandGroup">
                {
                    [
                        { v: "all", label: "All", cls: "ftab--all active" },
                        { v: "BNK48", label: "BNK48", cls: "ftab--bnk" },
                        { v: "CGM48", label: "CGM48", cls: "ftab--cgm" },
                    ].map(({ v, label, cls }) => (
                        <div class="col-4">
                            <button
                                class={`ftab ${cls} w-100`}
                                data-mf="brand"
                                data-mv={v}
                            >
                                {label}
                            </button>
                        </div>
                    ))
                }
            </div>
            <hr
                class="filter-divider-thick border-top border-secondary border-opacity-25 opacity-50 my-1 m-0"
            />
            <div id="mGenGroup"></div>
            <hr
                class="filter-divider-thick border-top border-secondary border-opacity-25 opacity-50 my-1 m-0 d-none"
                id="mGenDivider"
            />
            <div id="mTeamGroup"></div>
        </div>
        <div class="member-cards-grid" id="memberCardsGrid">
            {
                members.map((m: MemberRow) => {
                    const isBNK = m.brand === "BNK48";
                    const tc = resolveTeamColor(m.team, m.brand);
                    return (
                        <div
                            class="member-card slide-up"
                            data-name={m.name}
                            data-brand={m.brand}
                            data-gen={m.gen}
                            data-team={m.team}
                            data-img={m.profile_image_url ?? ""}
                        >
                            <div
                                class="member-card__img-wrap"
                                style={`--member-team-color:${tc}`}
                            >
                                {m.profile_image_url ? (
                                    <Image
                                        src={m.profile_image_url}
                                        alt={m.name}
                                        class="member-card__img"
                                        width={160}
                                        height={200}
                                        format="webp"
                                        loading="lazy"
                                        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                                    />
                                ) : null}
                                <div
                                    class={`member-card__fallback ${isBNK ? "av--bnk" : "av--cgm"}`}
                                    style={
                                        m.profile_image_url
                                            ? "display:none"
                                            : ""
                                    }
                                >
                                    {m.name[0]}
                                </div>
                            </div>
                            <div class="member-card__info p-2">
                                <div class="member-card__name">{m.name}</div>
                                <div class="d-flex align-items-center gap-1 mb-1">
                                    <span
                                        class={`brand-badge ${isBNK ? "bb--bnk" : "bb--cgm"}`}
                                    >
                                        {m.brand}
                                    </span>
                                    <span class="gen-text">{m.gen}</span>
                                </div>
                            </div>
                            <button
                                class="member-card__select-btn"
                                data-name={m.name}
                                onclick="toggleFromMembersTab(this)"
                                type="button"
                            >
                                <i class="fa-solid fa-circle-plus" /> Add to
                                Planner
                            </button>
                        </div>
                    );
                })
            }
        </div>
    </div>
</div>

<!-- TAB: PLANNER -->
<div class="sf-panel" id="panel-planner">
    <div class="sf-section-shell mx-auto p-4 pb-0">
        <div
            class="planner-empty flex-column align-items-center text-center py-5"
            id="plannerEmpty"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="36"
                height="36"
                fill="currentColor"
                viewBox="0 0 16 16"
                style="opacity:.3"
                class="mb-3"
            >
                <path
                    d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1zm-7.978-1L7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0M6.936 9.28a6 6 0 0 0-1.23-.247A7 7 0 0 0 5 9c-4 0-5 3-5 4q0 1 1 1h4.216A2.24 2.24 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816M4.92 10A5.5 5.5 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275ZM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0m3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4"
                ></path>
            </svg>
            <p class="fw-bold mb-1" style="color:var(--c-content)">
                ยังไม่ได้เลือก Member
            </p>
            <p class="mb-3 text-secondary planner-muted-text">
                ไปที่ Tab Members เพื่อเลือก Member ที่ต้องการ
            </p>
            <button class="btn-outline-sf" onclick="APP.switchTab('members')"
                >ไปที่ Members</button
            >
        </div>
        <div id="plannerContent" class="d-none">
            <div
                class="d-flex flex-column gap-3 p-4 rounded-4 filter-box mb-4 pb-0 mx-auto"
            >
                <div class="row g-2 mb-0" id="dayFilterRow">
                    <div class="col-6 col-sm-3">
                        <button class="day-ftab active w-100" data-day="all"
                            >All Days</button
                        >
                    </div>
                    {
                        days.map((d: DayConfig) => (
                            <div class="col-6 col-sm-3">
                                <button
                                    class={`day-ftab day-ftab--${d.key} w-100`}
                                    data-day={d.key}
                                >
                                    {d.label}
                                </button>
                            </div>
                        ))
                    }
                </div>
                <hr
                    class="filter-divider-thick border-top border-secondary border-opacity-25 opacity-50 my-1 m-0"
                />
                <div
                    class="row g-2 align-items-stretch mb-3"
                    id="actNameFilterRow"
                >
                </div>
            </div>
            <div
                class="d-flex flex-nowrap gap-2 mb-3 overflow-x-auto w-100"
                id="selectedMembersStrip"
                style="padding-bottom: 4px; scrollbar-width: none;"
            >
            </div>
            <div id="scheduleBlocks"></div>
        </div>
    </div>
</div>

<!-- TAB: HAPPENING NOW -->
<div class="sf-panel" id="panel-happening">
    <div class="sf-section-shell mx-auto p-4 pb-0">
        <div
            class="now-section-label now-section-label--live now-section-label--centered"
        >
            Live Happening Activities
        </div>
        <div id="nowContent"></div>
    </div>
</div>

<!-- TAB: SUMMARY -->
<div class="sf-panel" id="panel-summary">
    <div class="sf-section mx-auto">
        <div
